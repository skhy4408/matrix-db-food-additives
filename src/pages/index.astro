---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Load all additives
const additiveFiles = import.meta.glob('../data/additives/*.json', { eager: true });
const additives = Object.values(additiveFiles) as any[];

// Sort by E number
additives.sort((a, b) => {
  const aNum = parseInt((a.names?.e_number || '0').replace('E', '').replace(/[a-z]/i, ''));
  const bNum = parseInt((b.names?.e_number || '0').replace('E', '').replace(/[a-z]/i, ''));
  return aNum - bNum;
});

// Group by category
const byCategory = additives.reduce((acc, additive) => {
  const cat = additive.classification?.functional_class || 'Other';
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(additive);
  return acc;
}, {} as Record<string, typeof additives>);

// Count by status
const bannedSomewhere = additives.filter(a =>
  a.regulations?.eu?.status === 'banned' ||
  a.regulations?.usa?.status === 'banned' ||
  a.regulations?.japan?.status === 'banned'
);
---

<BaseLayout
  title="Food Additive Regulation Database | Matrix DB"
  description="Compare food additive regulations across EU, USA, Japan, Australia/NZ, and Canada. Official safety evaluations, ADI values, and regulatory status by country."
>
  <Header />

  <main class="space-y-16 pb-20">
    <!-- Hero Section -->
    <section class="relative bg-brand-900 overflow-hidden pt-16 pb-24">
      <!-- Background pattern/decoration -->
      <div class="absolute inset-0 opacity-10 pointer-events-none">
        <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
          <path d="M0 0 L100 0 L100 100 L0 100 Z" fill="url(#grid)" />
          <defs>
            <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
              <path d="M 10 0 L 0 0 0 10" fill="none" stroke="white" stroke-width="0.5"/>
            </pattern>
          </defs>
        </svg>
      </div>
      
      <div class="container relative z-10">
        <div class="max-w-4xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent/20 border border-accent/30 text-accent text-xs font-bold uppercase tracking-widest mb-6">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
            </span>
            Scientific Database
          </div>
          <h1 class="text-4xl md:text-6xl font-bold mb-6 text-white leading-tight">
            Cross-Country <span class="text-accent text-transparent bg-clip-text bg-gradient-to-r from-accent to-blue-400">Food Additive</span> Regulation Database
          </h1>
          <p class="text-xl md:text-2xl mb-12 text-brand-300 max-w-2xl mx-auto font-medium">
            Understand how different countries regulate the chemicals in your food. Compare 5 major regions instantly.
          </p>
          
          <div class="grid grid-cols-2 md:grid-cols-3 gap-6 max-w-3xl mx-auto">
            <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10">
              <div class="text-4xl font-bold text-white mb-1">{additives.length}</div>
              <div class="text-sm font-semibold text-brand-400 uppercase tracking-wider">Additives</div>
            </div>
            <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10">
              <div class="text-4xl font-bold text-white mb-1">5</div>
              <div class="text-sm font-semibold text-brand-400 uppercase tracking-wider">Regions</div>
            </div>
            <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10 col-span-2 md:col-span-1">
              <div class="text-4xl font-bold text-accent mb-1">{bannedSomewhere.length}</div>
              <div class="text-sm font-semibold text-brand-400 uppercase tracking-wider">Controversial</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Key Differences / Controversial Highlights -->
    <section class="container -mt-12 relative z-20">
      <div class="bg-white rounded-3xl shadow-xl border border-brand-100 p-8 md:p-12">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10">
          <div class="max-w-xl">
            <h2 class="text-3xl font-bold text-brand-900 mb-3">Key Regulatory Differences</h2>
            <p class="text-brand-500 font-medium italic">Why some additives are legal in the USA but banned in the EU (and vice versa).</p>
          </div>
          <a href="/compare/eu-vs-usa/" class="inline-flex items-center gap-2 font-semibold text-accent hover:text-accent-hover transition-colors">
            View full EU vs USA comparison →
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {additives.filter(a => ['e171', 'e952', 'e123', 'e211', 'e320'].includes((a.names?.e_number || '').toLowerCase())).slice(0, 3).map((additive) => (
            <a href={`/additive/${additive.slug}/`} class="group p-6 rounded-2xl border border-brand-100 hover:border-accent hover:shadow-lg transition-all bg-brand-50/30">
              <div class="flex items-center justify-between mb-4">
                <span class="text-xs font-bold text-brand-400 uppercase tracking-tighter">{additive.names?.e_number}</span>
                <span class="px-2 py-1 rounded-md bg-brand-200 text-brand-700 text-[10px] font-bold uppercase">Detail →</span>
              </div>
              <h3 class="text-lg font-bold text-brand-900 mb-4 group-hover:text-accent transition-colors">{additive.names?.common_name}</h3>
              
              <div class="space-y-3">
                <div class="flex items-center justify-between text-xs">
                  <span class="text-brand-500 font-medium">EU Status</span>
                  <span class={`font-bold px-2 py-0.5 rounded ${additive.regulations?.eu?.status === 'banned' ? 'bg-banned-bg text-banned-text' : 'bg-approved-bg text-approved-text'}`}>
                    {additive.regulations?.eu?.status || 'unverified'}
                  </span>
                </div>
                <div class="flex items-center justify-between text-xs">
                  <span class="text-brand-500 font-medium">USA Status</span>
                  <span class={`font-bold px-2 py-0.5 rounded ${additive.regulations?.usa?.status === 'banned' ? 'bg-banned-bg text-banned-text' : 'bg-approved-bg text-approved-text'}`}>
                    {additive.regulations?.usa?.status || 'unverified'}
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Browse by Category -->
    <section class="container">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-3xl font-bold text-brand-900 mb-4">Browse by Functional Class</h2>
        <p class="text-brand-500">Every additive is classified by its role in food production. Explore by category to understand common uses and risks.</p>
      </div>

      <div class="space-y-12">
        {Object.entries(byCategory).map(([category, items]) => (
          <div>
            <div class="flex items-center gap-4 mb-6">
              <h3 class="text-xl font-bold text-brand-900 capitalize whitespace-nowrap">{category}</h3>
              <div class="h-px w-full bg-brand-100"></div>
              <span class="text-sm font-bold text-brand-400">{items.length}</span>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
              {items.map((additive) => {
                const isBanned = additive.regulations?.eu?.status === 'banned' || 
                                additive.regulations?.usa?.status === 'banned' ||
                                additive.regulations?.japan?.status === 'banned' ||
                                additive.regulations?.canada?.status === 'banned' ||
                                additive.regulations?.australia?.status === 'banned';

                return (
                  <a
                    href={`/additive/${additive.slug}/`}
                    class="group block p-4 bg-white border border-brand-100 rounded-xl hover:shadow-md transition-all relative overflow-hidden"
                  >
                    {isBanned && <div class="absolute top-0 right-0 w-8 h-8 flex items-center justify-center"><div class="w-2 h-2 rounded-full bg-banned animate-pulse"></div></div>}
                    <div class="text-xs font-bold text-brand-400 mb-1">{additive.names?.e_number}</div>
                    <div class="font-bold text-brand-900 group-hover:text-accent transition-colors truncate">{additive.names?.common_name}</div>
                    <div class="mt-2 flex gap-1">
                      <div class={`h-1 flex-1 rounded-full ${additive.regulations?.eu?.status === 'approved' ? 'bg-approved' : additive.regulations?.eu?.status === 'banned' ? 'bg-banned' : 'bg-restricted'}`}></div>
                      <div class={`h-1 flex-1 rounded-full ${additive.regulations?.usa?.status === 'approved' ? 'bg-approved' : additive.regulations?.usa?.status === 'banned' ? 'bg-banned' : 'bg-restricted'}`}></div>
                      <div class={`h-1 flex-1 rounded-full ${additive.regulations?.japan?.status === 'approved' ? 'bg-approved' : additive.regulations?.japan?.status === 'banned' ? 'bg-banned' : 'bg-restricted'}`}></div>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Country Quick Access -->
    <section class="bg-brand-50 py-20">
      <div class="container">
        <div class="flex flex-col md:flex-row justify-between items-center gap-8 mb-12">
          <div>
            <h2 class="text-3xl font-bold text-brand-900 mb-2">Banned Additives by Region</h2>
            <p class="text-brand-500 font-medium">Quickly access the list of prohibited substances in your country.</p>
          </div>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
          {[
            { id: 'eu', name: 'European Union', flag: '🇪🇺' },
            { id: 'usa', name: 'United States', flag: '🇺🇸' },
            { id: 'japan', name: 'Japan', flag: '🇯🇵' },
            { id: 'canada', name: 'Canada', flag: '🇨🇦' },
            { id: 'australia', name: 'Australia/NZ', flag: '🇦🇺' },
          ].map((region) => (
            <a href={`/banned-in/${region.id}/`} class="group bg-white p-8 rounded-2xl border border-brand-200 hover:border-accent hover:shadow-xl transition-all text-center">
              <div class="text-5xl mb-6 transform group-hover:scale-110 transition-transform">{region.flag}</div>
              <h3 class="font-bold text-brand-900 mb-1">{region.name}</h3>
              <p class="text-[10px] uppercase tracking-widest font-bold text-brand-400">View Banned List</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Guides -->
    <section class="container">
      <div class="flex flex-col md:flex-row justify-between items-center gap-8 mb-12">
        <div>
          <h2 class="text-3xl font-bold text-brand-900 mb-2">Expert Educational Guides</h2>
          <p class="text-brand-500 font-medium">Deep dives into the science and history of food chemistry.</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          { 
            slug: 'what-are-e-numbers', 
            title: 'What Are E Numbers?', 
            desc: 'The complete history and classification system used in the European Union.',
            tag: 'Foundation'
          },
          { 
            slug: 'reading-food-labels', 
            title: 'Reading Food Labels', 
            desc: 'A practical guide to identifying hidden additives and understanding terminology.',
            tag: 'Practical'
          },
          { 
            slug: 'natural-vs-synthetic', 
            title: 'Natural vs Synthetic', 
            desc: 'Debunking myths about additive sources and their relative safety profiles.',
            tag: 'Science'
          },
        ].map(guide => (
          <a href={`/guides/${guide.slug}/`} class="group bg-white rounded-2xl border border-brand-100 overflow-hidden hover:shadow-2xl transition-all">
            <div class="p-8">
              <span class="inline-block px-3 py-1 rounded-full bg-brand-100 text-brand-600 text-[10px] font-bold uppercase tracking-widest mb-4">{guide.tag}</span>
              <h3 class="text-xl font-bold text-brand-900 mb-3 group-hover:text-accent transition-colors">{guide.title}</h3>
              <p class="text-brand-500 text-sm leading-relaxed mb-6">{guide.desc}</p>
              <span class="text-xs font-bold text-accent group-hover:underline">Read Full Article →</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Comparisons -->
    <section class="container">
      <div class="bg-brand-900 rounded-3xl p-8 md:p-16 relative overflow-hidden">
        <!-- Decoration -->
        <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 bg-accent/20 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 -ml-16 -mb-16 w-64 h-64 bg-blue-600/10 rounded-full blur-3xl pointer-events-none"></div>

        <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Regional Standards Comparison</h2>
            <p class="text-brand-300 mb-8 text-lg leading-relaxed">
              Different continents have fundamentally different philosophies on food safety. Explore our side-by-side comparisons to see the gaps.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {['eu-vs-usa', 'eu-vs-japan', 'usa-vs-japan', 'eu-vs-canada'].map(slug => (
                <a href={`/compare/${slug}/`} class="bg-white/10 hover:bg-white/20 border border-white/10 p-4 rounded-xl text-white font-bold text-sm text-center transition-colors uppercase tracking-widest">
                  {slug.replace('-vs-', ' vs ').toUpperCase()}
                </a>
              ))}
            </div>
          </div>
          <div class="hidden lg:block bg-white/5 border border-white/10 rounded-2xl p-8">
            <div class="space-y-4">
              <div class="flex items-center gap-4 text-brand-300 text-sm italic border-b border-white/10 pb-4">
                <span>"EU follows the Precautionary Principle"</span>
              </div>
              <div class="flex items-center gap-4 text-brand-300 text-sm italic border-b border-white/10 pb-4">
                <span>"USA prioritizes post-market surveillance"</span>
              </div>
              <div class="flex items-center gap-4 text-brand-300 text-sm italic border-b border-white/10 pb-4">
                <span>"Japan has unique historical standards"</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Search CTA -->
    <section class="container text-center py-10">
      <h2 class="text-2xl font-bold text-brand-900 mb-6">Looking for a specific E-Number?</h2>
      <a href="/search" class="inline-flex items-center gap-3 px-8 py-4 bg-accent hover:bg-accent-hover text-white rounded-2xl font-bold transition-all shadow-lg shadow-accent/20">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        Open Global Search
      </a>
    </section>
  </main>

  <Footer />
</BaseLayout>
