---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Load all additives
const additiveFiles = import.meta.glob('../data/additives/*.json', { eager: true });
const additives = Object.values(additiveFiles) as any[];

// Sort by E number
additives.sort((a, b) => {
  const aNum = parseInt(a.names.e_number.replace('E', '').replace(/[a-z]/i, ''));
  const bNum = parseInt(b.names.e_number.replace('E', '').replace(/[a-z]/i, ''));
  return aNum - bNum;
});

// Group by category
const byCategory = additives.reduce((acc, additive) => {
  const cat = additive.classification.functional_class;
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(additive);
  return acc;
}, {} as Record<string, typeof additives>);

// Count by status
const bannedSomewhere = additives.filter(a =>
  a.regulations.eu.status === 'banned' ||
  a.regulations.usa.status === 'banned' ||
  a.regulations.japan.status === 'banned'
);
---

<BaseLayout
  title="Food Additive Regulation Database | Matrix DB"
  description="Compare food additive regulations across EU, USA, Japan, Australia/NZ, and Canada. Official safety evaluations, ADI values, and regulatory status by country."
>
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-primary-600 to-primary-700 text-white py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <h1 class="text-4xl md:text-5xl font-bold mb-4">
            Food Additive Regulation Database
          </h1>
          <p class="text-xl md:text-2xl mb-8 text-primary-100">
            Compare food additive regulations across 5 regions
          </p>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4 text-center">
            <div class="bg-white/10 rounded-lg p-4">
              <div class="text-3xl font-bold">{additives.length}</div>
              <div class="text-sm text-primary-100">Additives</div>
            </div>
            <div class="bg-white/10 rounded-lg p-4">
              <div class="text-3xl font-bold">5</div>
              <div class="text-sm text-primary-100">Regions</div>
            </div>
            <div class="bg-white/10 rounded-lg p-4 col-span-2 md:col-span-1">
              <div class="text-3xl font-bold">{bannedSomewhere.length}</div>
              <div class="text-sm text-primary-100">Banned Somewhere</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Additives by Category -->
    <section class="container mx-auto px-4 py-12">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Browse by Category</h2>

      <div class="max-w-5xl mx-auto space-y-8">
        {Object.entries(byCategory).map(([category, items]) => (
          <div class="bg-white rounded-lg shadow-sm p-6">
            <h3 class="text-2xl font-semibold text-gray-900 mb-4 capitalize">
              {category} <span class="text-gray-500 text-lg">({items.length})</span>
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {items.map((additive) => {
                const hasBan = additive.regulations.eu.status === 'banned' ||
                              additive.regulations.usa.status === 'banned' ||
                              additive.regulations.japan.status === 'banned';

                return (
                  <a
                    href={`/additive/${additive.slug}/`}
                    class="block p-4 border border-gray-200 rounded-lg hover:border-primary-400 hover:shadow-md transition-all"
                  >
                    <div class="flex items-start justify-between mb-2">
                      <div>
                        <div class="font-semibold text-gray-900">{additive.names.common_name}</div>
                        <div class="text-sm text-gray-600">{additive.names.e_number}</div>
                      </div>
                      {hasBan && (
                        <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-danger-100 text-danger-800">
                          Banned
                        </span>
                      )}
                    </div>
                    {additive.names.aliases && additive.names.aliases.length > 0 && (
                      <div class="text-xs text-gray-500 mt-1">
                        {additive.names.aliases[0]}
                      </div>
                    )}
                  </a>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Featured Guides -->
    <section class="bg-white py-12">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold text-gray-900 mb-2 text-center">Educational Guides</h2>
          <p class="text-center text-gray-600 mb-8">Comprehensive guides to understanding food additives</p>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <a href="/guides/what-are-e-numbers/" class="block bg-gray-50 rounded-lg p-6 hover:shadow-lg transition-shadow">
              <h3 class="text-xl font-semibold text-gray-900 mb-2">What Are E Numbers?</h3>
              <p class="text-sm text-gray-600 mb-4">Complete guide to the European food additive numbering system, classification, and history.</p>
              <span class="text-primary-600 font-medium text-sm">Read Guide →</span>
            </a>

            <a href="/guides/reading-food-labels/" class="block bg-gray-50 rounded-lg p-6 hover:shadow-lg transition-shadow">
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Reading Food Labels</h3>
              <p class="text-sm text-gray-600 mb-4">Learn how to decode ingredient lists and understand additive labeling across different countries.</p>
              <span class="text-primary-600 font-medium text-sm">Read Guide →</span>
            </a>

            <a href="/guides/natural-vs-synthetic/" class="block bg-gray-50 rounded-lg p-6 hover:shadow-lg transition-shadow">
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Natural vs Synthetic</h3>
              <p class="text-sm text-gray-600 mb-4">Understanding the differences, safety considerations, and common misconceptions about additive sources.</p>
              <span class="text-primary-600 font-medium text-sm">Read Guide →</span>
            </a>

            <a href="/guides/understanding-preservatives/" class="block bg-gray-50 rounded-lg p-6 hover:shadow-lg transition-shadow">
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Understanding Preservatives</h3>
              <p class="text-sm text-gray-600 mb-4">How preservatives work, types of preservation, and the role they play in food safety.</p>
              <span class="text-primary-600 font-medium text-sm">Read Guide →</span>
            </a>

            <a href="/guides/artificial-colors/" class="block bg-gray-50 rounded-lg p-6 hover:shadow-lg transition-shadow">
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Artificial Food Colors</h3>
              <p class="text-sm text-gray-600 mb-4">Complete guide to food colors, safety debates, and the Southampton study on children's behavior.</p>
              <span class="text-primary-600 font-medium text-sm">Read Guide →</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Country Comparisons -->
    <section class="bg-gray-50 py-12">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold text-gray-900 mb-2 text-center">Compare Regulations by Country</h2>
          <p class="text-center text-gray-600 mb-8">See how different countries regulate the same food additives</p>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <a href="/compare/eu-vs-usa/" class="block bg-white rounded-lg p-4 border border-gray-200 hover:border-primary-400 hover:shadow-md transition-all">
              <div class="font-semibold text-gray-900 mb-1">🇪🇺 EU vs 🇺🇸 USA</div>
              <div class="text-sm text-gray-600">Compare European and American regulations</div>
            </a>

            <a href="/compare/eu-vs-japan/" class="block bg-white rounded-lg p-4 border border-gray-200 hover:border-primary-400 hover:shadow-md transition-all">
              <div class="font-semibold text-gray-900 mb-1">🇪🇺 EU vs 🇯🇵 Japan</div>
              <div class="text-sm text-gray-600">European vs Japanese standards</div>
            </a>

            <a href="/compare/usa-vs-japan/" class="block bg-white rounded-lg p-4 border border-gray-200 hover:border-primary-400 hover:shadow-md transition-all">
              <div class="font-semibold text-gray-900 mb-1">🇺🇸 USA vs 🇯🇵 Japan</div>
              <div class="text-sm text-gray-600">American vs Japanese regulations</div>
            </a>

            <a href="/compare/eu-vs-canada/" class="block bg-white rounded-lg p-4 border border-gray-200 hover:border-primary-400 hover:shadow-md transition-all">
              <div class="font-semibold text-gray-900 mb-1">🇪🇺 EU vs 🇨🇦 Canada</div>
              <div class="text-sm text-gray-600">European vs Canadian approach</div>
            </a>

            <a href="/compare/usa-vs-canada/" class="block bg-white rounded-lg p-4 border border-gray-200 hover:border-primary-400 hover:shadow-md transition-all">
              <div class="font-semibold text-gray-900 mb-1">🇺🇸 USA vs 🇨🇦 Canada</div>
              <div class="text-sm text-gray-600">North American neighbors compared</div>
            </a>

            <a href="/compare/eu-vs-australia/" class="block bg-white rounded-lg p-4 border border-gray-200 hover:border-primary-400 hover:shadow-md transition-all">
              <div class="font-semibold text-gray-900 mb-1">🇪🇺 EU vs 🇦🇺 AU/NZ</div>
              <div class="text-sm text-gray-600">European vs Australia/NZ standards</div>
            </a>
          </div>

          <div class="text-center mt-6">
            <a href="/compare/eu-vs-usa/" class="text-primary-600 hover:text-primary-700 font-medium">
              View All Comparisons →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Regulatory Timeline -->
    <section class="bg-white py-12">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold text-gray-900 mb-2 text-center">Regulatory History</h2>
          <p class="text-center text-gray-600 mb-8">Explore the timeline of controversial additives and regulatory changes</p>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <a href="/timeline/e171-titanium-dioxide/" class="block bg-gray-50 rounded-lg p-4 hover:shadow-lg transition-shadow">
              <div class="font-semibold text-gray-900 mb-1">E171 Titanium Dioxide</div>
              <div class="text-xs text-gray-600 mb-2">EU ban story (2022)</div>
              <div class="text-xs text-primary-600">View Timeline →</div>
            </a>

            <a href="/timeline/e951-aspartame/" class="block bg-gray-50 rounded-lg p-4 hover:shadow-lg transition-shadow">
              <div class="font-semibold text-gray-900 mb-1">E951 Aspartame</div>
              <div class="text-xs text-gray-600 mb-2">IARC 2B classification (2023)</div>
              <div class="text-xs text-primary-600">View Timeline →</div>
            </a>

            <a href="/timeline/e952-cyclamate/" class="block bg-gray-50 rounded-lg p-4 hover:shadow-lg transition-shadow">
              <div class="font-semibold text-gray-900 mb-1">E952 Cyclamate</div>
              <div class="text-xs text-gray-600 mb-2">USA ban, EU approval</div>
              <div class="text-xs text-primary-600">View Timeline →</div>
            </a>

            <a href="/timeline/e621-msg/" class="block bg-gray-50 rounded-lg p-4 hover:shadow-lg transition-shadow">
              <div class="font-semibold text-gray-900 mb-1">E621 MSG</div>
              <div class="text-xs text-gray-600 mb-2">Long-term safety debate</div>
              <div class="text-xs text-primary-600">View Timeline →</div>
            </a>

            <a href="/timeline/e102-tartrazine/" class="block bg-gray-50 rounded-lg p-4 hover:shadow-lg transition-shadow">
              <div class="font-semibold text-gray-900 mb-1">E102 Tartrazine</div>
              <div class="text-xs text-gray-600 mb-2">Children's behavior concerns</div>
              <div class="text-xs text-primary-600">View Timeline →</div>
            </a>

            <a href="/timeline/e320-bha/" class="block bg-gray-50 rounded-lg p-4 hover:shadow-lg transition-shadow">
              <div class="font-semibold text-gray-900 mb-1">E320 BHA</div>
              <div class="text-xs text-gray-600 mb-2">Carcinogenicity discussion</div>
              <div class="text-xs text-primary-600">View Timeline →</div>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Banned Lists Quick Links -->
    <section class="bg-gray-50 py-12">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold text-gray-900 mb-2 text-center">Banned Additives by Country</h2>
          <p class="text-center text-gray-600 mb-8">Explore additives prohibited in specific countries</p>

          <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4">
            <a href="/banned-in/eu/" class="block bg-white rounded-lg p-6 text-center hover:shadow-lg transition-shadow border-2 border-transparent hover:border-primary-400">
              <div class="text-4xl mb-2">🇪🇺</div>
              <div class="font-semibold text-gray-900">European Union</div>
              <div class="text-xs text-gray-600 mt-1">View banned list</div>
            </a>

            <a href="/banned-in/usa/" class="block bg-white rounded-lg p-6 text-center hover:shadow-lg transition-shadow border-2 border-transparent hover:border-primary-400">
              <div class="text-4xl mb-2">🇺🇸</div>
              <div class="font-semibold text-gray-900">United States</div>
              <div class="text-xs text-gray-600 mt-1">View banned list</div>
            </a>

            <a href="/banned-in/japan/" class="block bg-white rounded-lg p-6 text-center hover:shadow-lg transition-shadow border-2 border-transparent hover:border-primary-400">
              <div class="text-4xl mb-2">🇯🇵</div>
              <div class="font-semibold text-gray-900">Japan</div>
              <div class="text-xs text-gray-600 mt-1">View banned list</div>
            </a>

            <a href="/banned-in/canada/" class="block bg-white rounded-lg p-6 text-center hover:shadow-lg transition-shadow border-2 border-transparent hover:border-primary-400">
              <div class="text-4xl mb-2">🇨🇦</div>
              <div class="font-semibold text-gray-900">Canada</div>
              <div class="text-xs text-gray-600 mt-1">View banned list</div>
            </a>

            <a href="/banned-in/australia/" class="block bg-white rounded-lg p-6 text-center hover:shadow-lg transition-shadow border-2 border-transparent hover:border-primary-400">
              <div class="text-4xl mb-2">🇦🇺</div>
              <div class="font-semibold text-gray-900">Australia/NZ</div>
              <div class="text-xs text-gray-600 mt-1">View banned list</div>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Controversial Additives Highlight -->
    {bannedSomewhere.length > 0 && (
      <section class="bg-gray-50 py-12">
        <div class="container mx-auto px-4">
          <div class="max-w-4xl mx-auto">
            <h2 class="text-3xl font-bold text-gray-900 mb-4 text-center">
              Additives Banned in Some Countries
            </h2>
            <p class="text-center text-gray-600 mb-8">
              These additives have different regulatory status across countries
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {bannedSomewhere.map((additive) => (
                <a
                  href={`/additive/${additive.slug}/`}
                  class="bg-white p-6 rounded-lg shadow-sm hover:shadow-md transition-shadow"
                >
                  <div class="font-semibold text-gray-900 mb-2">
                    {additive.names.common_name} ({additive.names.e_number})
                  </div>
                  <div class="flex flex-wrap gap-2">
                    {additive.regulations.eu.status === 'banned' && (
                      <span class="text-xs px-2 py-1 bg-danger-100 text-danger-800 rounded">🇪🇺 Banned</span>
                    )}
                    {additive.regulations.usa.status === 'banned' && (
                      <span class="text-xs px-2 py-1 bg-danger-100 text-danger-800 rounded">🇺🇸 Banned</span>
                    )}
                    {additive.regulations.japan.status === 'banned' && (
                      <span class="text-xs px-2 py-1 bg-danger-100 text-danger-800 rounded">🇯🇵 Banned</span>
                    )}
                    {additive.regulations.canada.status === 'banned' && (
                      <span class="text-xs px-2 py-1 bg-danger-100 text-danger-800 rounded">🇨🇦 Banned</span>
                    )}
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
</BaseLayout>
