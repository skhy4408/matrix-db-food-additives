---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const title = 'What Are E Numbers? Complete Guide to European Food Additive Codes | Food Additive DB';
const description = 'Complete guide to E numbers: what they mean, how the system works, classification categories, and why the EU uses this numbering system for food additives.';

const breadcrumbs = [
  { name: 'Home', url: 'https://food.matrix-db.com/' },
  { name: 'Guides', url: 'https://food.matrix-db.com/guides/' },
  { name: 'What Are E Numbers?', url: 'https://food.matrix-db.com/guides/what-are-e-numbers/' }
];

// Load some related additives from different ranges
const additiveFiles = import.meta.glob('../../data/additives/*.json', { eager: true });
const allAdditives = Object.values(additiveFiles) as any[];
const featuredAdditives = allAdditives
  .filter(a => ['e100', 'e200', 'e300', 'e407', 'e621', 'e951'].includes(a.slug))
  .slice(0, 6);

const toc = [
  { id: 'basics', name: 'Understanding E Numbers' },
  { id: 'why-use-them', name: 'Why Does the EU Use Them?' },
  { id: 'history', name: 'History of the System' },
  { id: 'classification', name: 'Classification System' },
  { id: 'important-points', name: 'Important Points to Know' },
  { id: 'approval-process', name: 'How They Are Approved' },
  { id: 'regional-differences', name: 'Regional Differences' },
  { id: 'controversies', name: 'Controversial E Numbers' }
];
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="bg-brand-50 pb-20">
    <!-- Hero Section -->
    <div class="bg-white border-b border-brand-100 mb-12">
      <div class="container py-16 text-center max-w-4xl mx-auto">
        <nav class="flex justify-center text-xs font-semibold uppercase tracking-wider text-brand-400 mb-6">
          <a href="/" class="hover:text-accent">Home</a>
          <span class="mx-2">/</span>
          <a href="/guides/" class="hover:text-accent">Guides</a>
          <span class="mx-2">/</span>
          <span class="text-brand-900">What Are E Numbers?</span>
        </nav>
        <h1 class="text-4xl md:text-5xl font-black text-brand-900 mb-6 leading-tight">
          What Are <span class="text-accent">E Numbers?</span>
        </h1>
        <p class="text-xl text-brand-500 font-medium leading-relaxed italic">
          Decoding the European food additive classification system, from E100 to E1500 and beyond.
        </p>
      </div>
    </div>

    <div class="container max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        
        <!-- Sidebar: TOC & Related -->
        <aside class="lg:col-span-4 space-y-8 sticky top-8">
          <div class="bg-white rounded-3xl p-8 shadow-sm border border-brand-100">
            <h2 class="text-sm font-bold uppercase tracking-widest text-brand-900 mb-6 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M4 6h16"/><path d="M4 12h16"/><path d="M4 18h16"/></svg>
              Table of Contents
            </h2>
            <nav class="space-y-3">
              {toc.map(item => (
                <a href={`#${item.id}`} class="block text-sm font-bold text-brand-500 hover:text-accent transition-colors">
                  {item.name}
                </a>
              ))}
            </nav>
          </div>

          <div class="bg-brand-900 rounded-3xl p-8 shadow-lg shadow-brand-900/10 text-white">
            <h2 class="text-xs font-bold uppercase tracking-widest text-brand-400 mb-6">E Number Examples</h2>
            <div class="space-y-4">
              {featuredAdditives.map((related: any) => (
                <a href={`/additive/${related.slug}/`} class="block group">
                  <div class="flex items-center justify-between gap-3">
                    <div>
                      <div class="text-xs font-bold text-brand-300 mb-1">{related.names?.e_number}</div>
                      <div class="text-sm font-bold group-hover:text-accent transition-colors truncate max-w-[180px]">{related.names?.common_name}</div>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-600 group-hover:text-accent transition-colors"><path d="m9 18 6-6-6-6"/></svg>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </aside>

        <!-- Main Content -->
        <div class="lg:col-span-8 space-y-12">
          
          <div class="bg-white rounded-3xl p-8 md:p-12 shadow-sm border border-brand-100">
            <Disclaimer />
            
            <div class="bg-brand-900 text-white rounded-2xl p-8 mb-12 shadow-lg shadow-brand-900/10">
              <h2 class="text-xl font-bold mb-4 flex items-center gap-3">
                <span class="w-1.5 h-6 bg-accent rounded-full"></span>
                Key Takeaways
              </h2>
              <ul class="space-y-3 text-brand-200 text-sm font-medium">
                <li class="flex gap-3"><span class="text-accent font-bold">01.</span> E numbers are codes for food additives approved for use in the European Union (EFSA).</li>
                <li class="flex gap-3"><span class="text-accent font-bold">02.</span> They simplify labeling across multiple languages and save space on packaging labels.</li>
                <li class="flex gap-3"><span class="text-accent font-bold">03.</span> An E number indicates that the additive has undergone rigorous scientific safety assessment.</li>
                <li class="flex gap-3"><span class="text-accent font-bold">04.</span> Many E numbers are completely natural substances (e.g., E300 is Vitamin C).</li>
                <li class="flex gap-3"><span class="text-accent font-bold">05.</span> They are classified by range: E100s for colors, E200s for preservatives, E300s for antioxidants, etc.</li>
              </ul>
            </div>

            <article class="prose prose-brand max-w-none prose-headings:text-brand-900 prose-headings:font-black prose-p:text-brand-600 prose-li:text-brand-600">
              <p class="text-xl text-brand-500 font-medium mb-8 leading-relaxed">
                E numbers are codes for food additives approved for use in the European Union. This comprehensive guide explains what E numbers mean, how the system works, and what you need to know when reading food labels.
              </p>

              <h2 id="basics">Understanding E Numbers: The Basics</h2>

              <p>
                E numbers are a standardized system for identifying food additives. The "E" stands for "Europe" (or "European"), and the number that follows indicates a specific additive substance. For example, "E300" refers to ascorbic acid (Vitamin C).
              </p>

              <h2 id="why-use-them">Why Does the EU Use E Numbers?</h2>

              <ul>
                <li><strong>Language Uniformity:</strong> Eliminates translation errors across the EU's 24 official languages.</li>
                <li><strong>Space Efficiency:</strong> Long chemical names are replaced by short, 3 or 4-digit codes.</li>
                <li><strong>Safety Assurance:</strong> Indicates the substance has been assessed by the European Food Safety Authority (EFSA).</li>
              </ul>

              <h2 id="history">History of the E Number System</h2>

              <p>
                First introduced in the 1960s to harmonize food regulations. The system originally covered primarily colors and preservatives but has since expanded to include sweeteners, stabilizers, and flavor enhancers.
              </p>

              <h2 id="classification">E Number Classification System</h2>

              <ul>
                <li><strong>E100-E199: Colors</strong> — Add or restore color (e.g., E100 Curcumin).</li>
                <li><strong>E200-E299: Preservatives</strong> — Prevent microbial growth (e.g., E211 Sodium Benzoate).</li>
                <li><strong>E300-E399: Antioxidants & Acidity Regulators</strong> — Prevent oxidation and control pH (e.g., E330 Citric Acid).</li>
                <li><strong>E400-E499: Thickeners, Stabilizers & Emulsifiers</strong> — Affect texture and consistency (e.g., E415 Xanthan Gum).</li>
                <li><strong>E500-E599: pH Regulators & Anti-Caking Agents</strong> — Prevent clumping (e.g., E551 Silicon Dioxide).</li>
                <li><strong>E600-E699: Flavor Enhancers</strong> — Intensify flavor (e.g., E621 MSG).</li>
                <li><strong>E900-E999: Glazing Agents, Gases & Sweeteners</strong> — (e.g., E951 Aspartame).</li>
              </ul>

              <h2 id="important-points">Important Points About E Numbers</h2>

              <p>
                An E number does <strong>NOT</strong> mean a substance is harmful. Many are natural (like Vitamin C or Turmeric). It simply means they have been evaluated and deemed safe for use at specified levels.
              </p>

              <h2 id="approval-process">How E Numbers Are Approved</h2>

              <p>The process involves a formal application, a rigorous scientific review by EFSA, toxicology studies, and the establishment of an Acceptable Daily Intake (ADI) before final approval by the European Commission.</p>

              <h2 id="regional-differences">Regional Differences</h2>

              <p>
                While primarily European, many countries use the similar International Numbering System (INS), which often uses the same numbers but without the "E" prefix (e.g., INS 300). The United States and Canada do not use this system, listing additives by name instead.
              </p>

              <h2 id="controversies">Controversial E Numbers</h2>

              <p>
                Some E numbers remain subject to debate, such as the "Southampton Six" colors which require behavioral warnings in the EU, and Titanium Dioxide (E171) which was recently banned in the EU but remains approved in the US.
              </p>

              <h2>Conclusion</h2>

              <p>
                E numbers provide transparency and standardization in food labeling. Understanding them empowers consumers to make informed decisions about the additives present in their food.
              </p>

              <p class="text-sm text-brand-400 italic mt-8 border-t border-brand-100 pt-8">
                <strong>Note:</strong> This guide is for informational purposes only. For health concerns related to specific additives, consult healthcare professionals. For current regulatory status, consult official EFSA and EU sources.
              </p>
            </article>

            <div class="mt-12 pt-8 border-t border-brand-100">
              <h2 class="text-2xl font-black text-brand-900 mb-6">Further Reading</h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <a href="/guides/reading-food-labels/" class="p-6 bg-brand-50 rounded-2xl border border-brand-100 hover:border-accent transition-all group">
                  <h3 class="font-bold text-brand-900 group-hover:text-accent mb-2">How to Read Food Labels</h3>
                  <p class="text-sm text-brand-600">Learn how E numbers and other additives are listed on packaging.</p>
                </a>
                <a href="/guides/natural-vs-synthetic/" class="p-6 bg-brand-50 rounded-2xl border border-brand-100 hover:border-accent transition-all group">
                  <h3 class="font-bold text-brand-900 group-hover:text-accent mb-2">Natural vs Synthetic</h3>
                  <p class="text-sm text-brand-600">Understand the difference between naturally-derived and synthetic additives.</p>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
  <BreadcrumbSchema items={breadcrumbs} />
</BaseLayout>


