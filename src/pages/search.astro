---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Search Food Additives | Food Additive DB"
  description="Search our database of food additives by E number, name, or regulation status."
>
  <Header />

  <main class="bg-brand-50 min-h-screen pb-20">
    <div class="bg-white border-b border-brand-100 mb-12">
      <div class="container py-16 text-center">
        <h1 class="text-4xl md:text-5xl font-black text-brand-900 mb-6">
          Search <span class="text-accent">Food Additive</span> Database
        </h1>
        <p class="text-lg text-brand-500 max-w-2xl mx-auto font-medium leading-relaxed">
          Access comprehensive regulatory data, chemical classifications, and safety information by searching for E-numbers or common names.
        </p>
      </div>
    </div>

    <div class="container">
      <div class="max-w-4xl mx-auto bg-white p-8 md:p-12 rounded-3xl border border-brand-100 shadow-sm">
        <div id="search" class="min-h-[200px]"></div>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="bg-brand-100/50 p-6 rounded-2xl border border-brand-100">
          <div class="text-accent font-black mb-2 uppercase tracking-widest text-[10px]">Tip 01</div>
          <h3 class="font-bold text-brand-900 mb-2">E-Number Search</h3>
          <p class="text-sm text-brand-500">Try searching for specific codes like <code class="bg-white px-1 rounded">E171</code> or <code class="bg-white px-1 rounded">E951</code>.</p>
        </div>
        <div class="bg-brand-100/50 p-6 rounded-2xl border border-brand-100">
          <div class="text-accent font-black mb-2 uppercase tracking-widest text-[10px]">Tip 02</div>
          <h3 class="font-bold text-brand-900 mb-2">Common Names</h3>
          <p class="text-sm text-brand-500">Search by name, such as <code class="bg-white px-1 rounded">Aspartame</code> or <code class="bg-white px-1 rounded">Curcumin</code>.</p>
        </div>
        <div class="bg-brand-100/50 p-6 rounded-2xl border border-brand-100">
          <div class="text-accent font-black mb-2 uppercase tracking-widest text-[10px]">Tip 03</div>
          <h3 class="font-bold text-brand-900 mb-2">Functions</h3>
          <p class="text-sm text-brand-500">Find by usage like <code class="bg-white px-1 rounded">Color</code>, <code class="bg-white px-1 rounded">Sweetener</code>, or <code class="bg-white px-1 rounded">Preservative</code>.</p>
        </div>
      </div>
    </div>
  </main>

  <Footer />

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet">
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      new PagefindUI({
        element: "#search",
        showSubResults: true,
        showImages: false,
        excerptLength: 40,
        translations: {
          placeholder: "Type E-number or name (e.g. E102, Titanium Dioxide...)"
        }
      });
    });
  </script>

  <style is:global>
    :root {
      --pagefind-ui-primary: var(--color-accent);
      --pagefind-ui-text: var(--color-brand-900);
      --pagefind-ui-background: #ffffff;
      --pagefind-ui-border: var(--color-brand-200);
      --pagefind-ui-font: var(--font-family-sans);
    }

    .pagefind-ui .pagefind-ui__search-input {
      border-radius: 1rem !important;
      padding: 1rem 1.5rem !important;
      font-weight: 600 !important;
    }

    .pagefind-ui .pagefind-ui__result-link {
      color: var(--color-brand-900) !important;
      font-weight: 800 !important;
      text-decoration: none !important;
    }

    .pagefind-ui .pagefind-ui__result-link:hover {
      color: var(--color-accent) !important;
    }

    .pagefind-ui .pagefind-ui__result-excerpt {
      color: var(--color-brand-500) !important;
      font-size: 0.875rem !important;
      line-height: 1.6 !important;
    }
  </style>
</BaseLayout>
