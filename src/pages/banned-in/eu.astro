---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const additiveFiles = import.meta.glob('../../data/additives/*.json', { eager: true });
const allAdditives = Object.values(additiveFiles) as any[];

const bannedInEU = allAdditives.filter(a => a.regulations.eu.status === 'banned');

const title = 'Food Additives Banned in the European Union (EU) | Food Additive DB';
const description = `Complete list of ${bannedInEU.length} food additives that are banned in the European Union. Compare with approval status in USA, Japan, Canada, and Australia/NZ.`;

const breadcrumbs = [
  { name: 'Home', url: 'https://food.matrix-db.com/' },
  { name: 'Banned Lists', url: 'https://food.matrix-db.com/' },
  { name: 'Banned in EU', url: 'https://food.matrix-db.com/banned-in/eu/' }
];
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="container mx-auto px-4 py-8">
    <div class="max-w-6xl mx-auto">
      <Disclaimer />

      <h1 class="text-4xl font-bold text-gray-900 mb-2">
        Food Additives Banned in the EU
      </h1>
      <p class="text-xl text-gray-600 mb-8">
        Additives that are not permitted for use in food products in the European Union
      </p>

      <!-- Summary Stats -->
      <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-8">
        <div class="flex items-center justify-between mb-4">
          <div>
            <div class="text-3xl font-bold text-red-900">{bannedInEU.length}</div>
            <div class="text-sm text-red-700">Additives Banned in EU</div>
          </div>
          <div class="text-right">
            <div class="text-sm text-red-700">As of April 2026</div>
            <div class="text-xs text-red-600">Based on Regulation (EC) No 1333/2008</div>
          </div>
        </div>
        <p class="text-sm text-red-800">
          The European Union maintains a strict precautionary approach to food additives.
          Additives must be proven safe before approval and can be removed from the permitted list if new evidence emerges.
        </p>
      </div>

      <!-- Regulatory Authority Info -->
      <section class="bg-white rounded-lg shadow-sm p-6 mb-6">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">EU Regulatory Framework</h2>
        <dl class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
          <div>
            <dt class="font-medium text-gray-700">Primary Authority:</dt>
            <dd class="text-gray-600">European Food Safety Authority (EFSA)</dd>
          </div>
          <div>
            <dt class="font-medium text-gray-700">Regulatory Framework:</dt>
            <dd class="text-gray-600">Regulation (EC) No 1333/2008</dd>
          </div>
          <div>
            <dt class="font-medium text-gray-700">Approach:</dt>
            <dd class="text-gray-600">Precautionary principle - additives must be proven safe before approval</dd>
          </div>
          <div>
            <dt class="font-medium text-gray-700">Re-evaluation:</dt>
            <dd class="text-gray-600">All approved additives undergo periodic re-evaluation</dd>
          </div>
        </dl>
      </section>

      <!-- Banned Additives Table -->
      {bannedInEU.length > 0 ? (
        <section class="bg-white rounded-lg shadow-sm p-6 mb-6">
          <h2 class="text-2xl font-semibold text-gray-900 mb-4">Banned Additives List</h2>
          <p class="text-sm text-gray-600 mb-4">
            The following additives are banned in the EU but may be approved in other countries:
          </p>

          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Additive</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Functional Class</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">🇺🇸 USA</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">🇯🇵 Japan</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">🇨🇦 Canada</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">🇦🇺 AU/NZ</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                {bannedInEU.map((additive: any) => (
                  <tr class="hover:bg-gray-50">
                    <td class="px-4 py-3">
                      <a href={`/additive/${additive.slug}/`} class="text-blue-600 hover:underline font-medium">
                        {additive.names.common_name}
                      </a>
                      <div class="text-xs text-gray-500">{additive.names.e_number}</div>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-700">{additive.classification.functional_class}</td>
                    <td class="px-4 py-3 text-center">
                      <span class={`inline-block px-2 py-1 text-xs font-medium rounded ${
                        additive.regulations.usa.status === 'approved' ? 'bg-green-100 text-green-800' :
                        additive.regulations.usa.status === 'banned' ? 'bg-red-100 text-red-800' :
                        'bg-gray-100 text-gray-800'
                      }`}>
                        {additive.regulations.usa.status}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-center">
                      <span class={`inline-block px-2 py-1 text-xs font-medium rounded ${
                        additive.regulations.japan.status === 'approved' ? 'bg-green-100 text-green-800' :
                        additive.regulations.japan.status === 'banned' ? 'bg-red-100 text-red-800' :
                        'bg-gray-100 text-gray-800'
                      }`}>
                        {additive.regulations.japan.status}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-center">
                      <span class={`inline-block px-2 py-1 text-xs font-medium rounded ${
                        additive.regulations.canada.status === 'approved' ? 'bg-green-100 text-green-800' :
                        additive.regulations.canada.status === 'banned' ? 'bg-red-100 text-red-800' :
                        'bg-gray-100 text-gray-800'
                      }`}>
                        {additive.regulations.canada.status}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-center">
                      <span class={`inline-block px-2 py-1 text-xs font-medium rounded ${
                        additive.regulations.australia_nz.status === 'approved' ? 'bg-green-100 text-green-800' :
                        additive.regulations.australia_nz.status === 'banned' ? 'bg-red-100 text-red-800' :
                        'bg-gray-100 text-gray-800'
                      }`}>
                        {additive.regulations.australia_nz.status}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      ) : (
        <section class="bg-white rounded-lg shadow-sm p-6 mb-6">
          <p class="text-gray-600">
            Based on our current database, there are no additives specifically banned in the EU while being approved elsewhere.
            The EU approval process requires comprehensive safety evaluation before any additive can be used.
          </p>
        </section>
      )}

      <!-- Important Notes -->
      <section class="bg-gray-50 border border-gray-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-3">Important Information</h3>
        <ul class="space-y-2 text-sm text-gray-700">
          <li class="flex items-start">
            <svg class="w-5 h-5 text-gray-400 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
            </svg>
            <span><strong>Ban vs Not Approved:</strong> "Banned" may mean either actively prohibited or simply not on the approved list.</span>
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 text-gray-400 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
            </svg>
            <span><strong>Reasons for Ban:</strong> Bans may be based on safety concerns, lack of technological need, or insufficient evidence of safety.</span>
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 text-gray-400 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1 a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
            </svg>
            <span><strong>Other Countries:</strong> Approval in other countries does not indicate EU approval is unjustified. Each regulatory authority evaluates based on their own standards and available evidence.</span>
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 text-gray-400 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
            </svg>
            <span><strong>This is not safety advice:</strong> This page is for informational purposes only. Consult official EU sources for current regulations.</span>
          </li>
        </ul>
      </section>

      <!-- Data Sources -->
      <section class="bg-gray-50 border border-gray-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-3">Data Sources</h3>
        <ul class="space-y-2 text-sm text-gray-700">
          <li>• <strong>EU:</strong> Regulation (EC) No 1333/2008, EFSA Scientific Opinions</li>
          <li>• <strong>Comparative Data:</strong> USA (21 CFR), Japan (MHLW), Canada (Health Canada), AU/NZ (FSANZ)</li>
          <li>• Data current as of April 2026</li>
        </ul>
      </section>
    </div>
  </main>

  <Footer />
  <BreadcrumbSchema items={breadcrumbs} />
</BaseLayout>
