---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const additiveFiles = import.meta.glob('../../data/additives/*.json', { eager: true });
const allAdditives = Object.values(additiveFiles) as any[];

const bannedInAustralia = allAdditives.filter(a => a.regulations.australia_nz.status === 'banned');

const title = 'Food Additives Banned in Australia/New Zealand | Food Additive DB';
const description = `Complete list of ${bannedInAustralia.length} food additives that are banned in Australia and New Zealand. Compare with approval status in EU, USA, Japan, and Canada.`;

const breadcrumbs = [
  { name: 'Home', url: 'https://food.matrix-db.com/' },
  { name: 'Banned Lists', url: 'https://food.matrix-db.com/' },
  { name: 'Banned in Australia/NZ', url: 'https://food.matrix-db.com/banned-in/australia/' }
];
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="container mx-auto px-4 py-8">
    <div class="max-w-6xl mx-auto">
      <Disclaimer />

      <h1 class="text-4xl font-bold text-gray-900 mb-2">
        Food Additives Banned in Australia / New Zealand
      </h1>
      <p class="text-xl text-gray-600 mb-8">
        Additives that are not permitted for use in food products in Australia and New Zealand
      </p>

      <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-8">
        <div class="flex items-center justify-between mb-4">
          <div>
            <div class="text-3xl font-bold text-red-900">{bannedInAustralia.length}</div>
            <div class="text-sm text-red-700">Additives Banned in AU/NZ</div>
          </div>
          <div class="text-right">
            <div class="text-sm text-red-700">As of April 2026</div>
            <div class="text-xs text-red-600">Based on FSANZ Food Standards Code</div>
          </div>
        </div>
        <p class="text-sm text-red-800">
          Food Standards Australia New Zealand (FSANZ) regulates food additives under the Australia New Zealand Food Standards Code.
          Only additives approved under specific schedules may be used in food products.
        </p>
      </div>

      <section class="bg-white rounded-lg shadow-sm p-6 mb-6">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">AU/NZ Regulatory Framework</h2>
        <dl class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
          <div>
            <dt class="font-medium text-gray-700">Primary Authority:</dt>
            <dd class="text-gray-600">Food Standards Australia New Zealand (FSANZ)</dd>
          </div>
          <div>
            <dt class="font-medium text-gray-700">Framework:</dt>
            <dd class="text-gray-600">Australia New Zealand Food Standards Code</dd>
          </div>
          <div>
            <dt class="font-medium text-gray-700">System:</dt>
            <dd class="text-gray-600">Positive list in schedules (e.g., Schedule 15, 16)</dd>
          </div>
          <div>
            <dt class="font-medium text-gray-700">Approach:</dt>
            <dd class="text-gray-600">Risk-based assessment with pre-market approval</dd>
          </div>
        </dl>
      </section>

      {bannedInAustralia.length > 0 ? (
        <section class="bg-white rounded-lg shadow-sm p-6 mb-6">
          <h2 class="text-2xl font-semibold text-gray-900 mb-4">Banned Additives List</h2>
          <p class="text-sm text-gray-600 mb-4">
            The following additives are banned in Australia/NZ but may be approved in other countries:
          </p>

          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Additive</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Functional Class</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">🇪🇺 EU</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">🇺🇸 USA</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">🇯🇵 Japan</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">🇨🇦 Canada</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                {bannedInAustralia.map((additive: any) => (
                  <tr class="hover:bg-gray-50">
                    <td class="px-4 py-3">
                      <a href={`/additive/${additive.slug}/`} class="text-blue-600 hover:underline font-medium">
                        {additive.names.common_name}
                      </a>
                      <div class="text-xs text-gray-500">{additive.names.e_number}</div>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-700">{additive.classification.functional_class}</td>
                    <td class="px-4 py-3 text-center">
                      <span class={`inline-block px-2 py-1 text-xs font-medium rounded ${
                        additive.regulations.eu.status === 'approved' ? 'bg-green-100 text-green-800' :
                        additive.regulations.eu.status === 'banned' ? 'bg-red-100 text-red-800' :
                        'bg-gray-100 text-gray-800'
                      }`}>
                        {additive.regulations.eu.status}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-center">
                      <span class={`inline-block px-2 py-1 text-xs font-medium rounded ${
                        additive.regulations.usa.status === 'approved' ? 'bg-green-100 text-green-800' :
                        additive.regulations.usa.status === 'banned' ? 'bg-red-100 text-red-800' :
                        'bg-gray-100 text-gray-800'
                      }`}>
                        {additive.regulations.usa.status}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-center">
                      <span class={`inline-block px-2 py-1 text-xs font-medium rounded ${
                        additive.regulations.japan.status === 'approved' ? 'bg-green-100 text-green-800' :
                        additive.regulations.japan.status === 'banned' ? 'bg-red-100 text-red-800' :
                        'bg-gray-100 text-gray-800'
                      }`}>
                        {additive.regulations.japan.status}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-center">
                      <span class={`inline-block px-2 py-1 text-xs font-medium rounded ${
                        additive.regulations.canada.status === 'approved' ? 'bg-green-100 text-green-800' :
                        additive.regulations.canada.status === 'banned' ? 'bg-red-100 text-red-800' :
                        'bg-gray-100 text-gray-800'
                      }`}>
                        {additive.regulations.canada.status}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      ) : (
        <section class="bg-white rounded-lg shadow-sm p-6 mb-6">
          <p class="text-gray-600">
            Based on our current database, there are no additives in this list that are specifically banned in Australia/NZ while being approved elsewhere.
          </p>
        </section>
      )}

      <section class="bg-gray-50 border border-gray-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-3">Important Information</h3>
        <ul class="space-y-2 text-sm text-gray-700">
          <li>• <strong>Joint System:</strong> Australia and New Zealand share a unified food standards system under FSANZ</li>
          <li>• <strong>Schedule-based:</strong> Additives are listed in specific schedules within the Food Standards Code</li>
          <li>• <strong>International Alignment:</strong> FSANZ often considers JECFA and other international assessments</li>
          <li>• <strong>Not Safety Advice:</strong> This page is informational only. Consult FSANZ for current regulations.</li>
        </ul>
      </section>

      <section class="bg-gray-50 border border-gray-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-3">Data Sources</h3>
        <ul class="space-y-2 text-sm text-gray-700">
          <li>• <strong>AU/NZ:</strong> FSANZ (Food Standards Australia New Zealand) Food Standards Code</li>
          <li>• <strong>Comparative Data:</strong> EU (Regulation 1333/2008), USA (21 CFR), Japan (MHLW), Canada (Health Canada)</li>
          <li>• Data current as of April 2026</li>
        </ul>
      </section>
    </div>
  </main>

  <Footer />
  <BreadcrumbSchema items={breadcrumbs} />
</BaseLayout>
