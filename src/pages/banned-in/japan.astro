---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const additiveFiles = import.meta.glob('../../data/additives/*.json', { eager: true });
const allAdditives = Object.values(additiveFiles) as any[];

const bannedInJapan = allAdditives.filter(a => a.regulations.japan.status === 'banned');

const title = 'Food Additives Banned in Japan | Food Additive DB';
const description = `Complete list of ${bannedInJapan.length} food additives that are banned in Japan. Compare with approval status in EU, USA, Canada, and Australia/NZ.`;

const breadcrumbs = [
  { name: 'Home', url: 'https://food.matrix-db.com/' },
  { name: 'Banned Lists', url: 'https://food.matrix-db.com/' },
  { name: 'Banned in Japan', url: 'https://food.matrix-db.com/banned-in/japan/' }
];
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="container mx-auto px-4 py-8">
    <div class="max-w-6xl mx-auto">
      <Disclaimer />

      <h1 class="text-4xl font-bold text-gray-900 mb-2">
        Food Additives Banned in Japan
      </h1>
      <p class="text-xl text-gray-600 mb-8">
        Additives that are not permitted for use in food products in Japan
      </p>

      <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-8">
        <div class="flex items-center justify-between mb-4">
          <div>
            <div class="text-3xl font-bold text-red-900">{bannedInJapan.length}</div>
            <div class="text-sm text-red-700">Additives Banned in Japan</div>
          </div>
          <div class="text-right">
            <div class="text-sm text-red-700">As of April 2026</div>
            <div class="text-xs text-red-600">Based on MHLW Food Additive Lists</div>
          </div>
        </div>
        <p class="text-sm text-red-800">
          Japan operates a positive list system where only designated additives (指定添加物) and existing additives (既存添加物) are permitted.
          Additives not on these lists cannot be used in food products.
        </p>
      </div>

      <section class="bg-white rounded-lg shadow-sm p-6 mb-6">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">Japan Regulatory Framework</h2>
        <dl class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
          <div>
            <dt class="font-medium text-gray-700">Primary Authority:</dt>
            <dd class="text-gray-600">Ministry of Health, Labour and Welfare (MHLW / 厚生労働省)</dd>
          </div>
          <div>
            <dt class="font-medium text-gray-700">System:</dt>
            <dd class="text-gray-600">Positive list system (ポジティブリスト制度)</dd>
          </div>
          <div>
            <dt class="font-medium text-gray-700">Categories:</dt>
            <dd class="text-gray-600">指定添加物 (Designated) and 既存添加物 (Existing Additives)</dd>
          </div>
          <div>
            <dt class="font-medium text-gray-700">Approach:</dt>
            <dd class="text-gray-600">Only listed additives permitted; all others prohibited by default</dd>
          </div>
        </dl>
      </section>

      {bannedInJapan.length > 0 ? (
        <section class="bg-white rounded-lg shadow-sm p-6 mb-6">
          <h2 class="text-2xl font-semibold text-gray-900 mb-4">Banned Additives List</h2>
          <p class="text-sm text-gray-600 mb-4">
            The following additives are banned in Japan but may be approved in other countries:
          </p>

          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Additive</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Functional Class</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">🇪🇺 EU</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">🇺🇸 USA</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">🇨🇦 Canada</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">🇦🇺 AU/NZ</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                {bannedInJapan.map((additive: any) => (
                  <tr class="hover:bg-gray-50">
                    <td class="px-4 py-3">
                      <a href={`/additive/${additive.slug}/`} class="text-blue-600 hover:underline font-medium">
                        {additive.names.common_name}
                      </a>
                      <div class="text-xs text-gray-500">{additive.names.e_number}</div>
                      {additive.names.japanese_name && (
                        <div class="text-xs text-gray-600 mt-1">{additive.names.japanese_name}</div>
                      )}
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-700">{additive.classification.functional_class}</td>
                    <td class="px-4 py-3 text-center">
                      <span class={`inline-block px-2 py-1 text-xs font-medium rounded ${
                        additive.regulations.eu.status === 'approved' ? 'bg-green-100 text-green-800' :
                        additive.regulations.eu.status === 'banned' ? 'bg-red-100 text-red-800' :
                        'bg-gray-100 text-gray-800'
                      }`}>
                        {additive.regulations.eu.status}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-center">
                      <span class={`inline-block px-2 py-1 text-xs font-medium rounded ${
                        additive.regulations.usa.status === 'approved' ? 'bg-green-100 text-green-800' :
                        additive.regulations.usa.status === 'banned' ? 'bg-red-100 text-red-800' :
                        'bg-gray-100 text-gray-800'
                      }`}>
                        {additive.regulations.usa.status}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-center">
                      <span class={`inline-block px-2 py-1 text-xs font-medium rounded ${
                        additive.regulations.canada.status === 'approved' ? 'bg-green-100 text-green-800' :
                        additive.regulations.canada.status === 'banned' ? 'bg-red-100 text-red-800' :
                        'bg-gray-100 text-gray-800'
                      }`}>
                        {additive.regulations.canada.status}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-center">
                      <span class={`inline-block px-2 py-1 text-xs font-medium rounded ${
                        additive.regulations.australia_nz.status === 'approved' ? 'bg-green-100 text-green-800' :
                        additive.regulations.australia_nz.status === 'banned' ? 'bg-red-100 text-red-800' :
                        'bg-gray-100 text-gray-800'
                      }`}>
                        {additive.regulations.australia_nz.status}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      ) : (
        <section class="bg-white rounded-lg shadow-sm p-6 mb-6">
          <p class="text-gray-600">
            Based on our current database, there are no additives in this list that are specifically banned in Japan while being approved elsewhere.
          </p>
        </section>
      )}

      <section class="bg-gray-50 border border-gray-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-3">Important Information</h3>
        <ul class="space-y-2 text-sm text-gray-700">
          <li>• <strong>Positive List System:</strong> Only additives on designated or existing additive lists are permitted</li>
          <li>• <strong>Natural vs Synthetic:</strong> Japan distinguishes between natural food additives and synthetic additives</li>
          <li>• <strong>既存添加物:</strong> Existing additives used traditionally in Japan before modern regulations</li>
          <li>• <strong>Not Safety Advice:</strong> This page is informational only. Consult MHLW sources for current regulations.</li>
        </ul>
      </section>

      <section class="bg-gray-50 border border-gray-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-3">Data Sources</h3>
        <ul class="space-y-2 text-sm text-gray-700">
          <li>• <strong>Japan:</strong> MHLW (厚生労働省) Food Additive Lists</li>
          <li>• <strong>Comparative Data:</strong> EU (Regulation 1333/2008), USA (21 CFR), Canada (Health Canada), AU/NZ (FSANZ)</li>
          <li>• Data current as of April 2026</li>
        </ul>
      </section>
    </div>
  </main>

  <Footer />
  <BreadcrumbSchema items={breadcrumbs} />
</BaseLayout>
