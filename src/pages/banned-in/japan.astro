---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const additiveFiles = import.meta.glob('../../data/additives/*.json', { eager: true });
const allAdditives = Object.values(additiveFiles) as any[];

const bannedInJapan = allAdditives.filter(a => a.regulations.japan.status === 'banned');

const title = 'Food Additives Banned in Japan | Food Additive DB';
const description = `Complete list of ${bannedInJapan.length} food additives that are banned in Japan. Compare with approval status in EU, USA, Canada, and Australia/NZ.`;

const breadcrumbs = [
  { name: 'Home', url: 'https://food.matrix-db.com/' },
  { name: 'Banned Lists', url: 'https://food.matrix-db.com/' },
  { name: 'Banned in Japan', url: 'https://food.matrix-db.com/banned-in/japan/' }
];
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="bg-brand-50 pb-20">
    <!-- Hero & Breadcrumbs -->
    <div class="bg-white border-b border-brand-100 mb-12">
      <div class="container py-4">
        <nav class="flex text-xs font-semibold uppercase tracking-wider text-brand-400 mb-8">
          <a href="/" class="hover:text-accent">Home</a>
          <span class="mx-2">/</span>
          <span class="text-brand-900 uppercase">Banned Lists</span>
          <span class="mx-2">/</span>
          <span class="text-banned uppercase font-black tracking-widest">Banned in Japan</span>
        </nav>

        <div class="flex flex-col md:flex-row md:items-center justify-between gap-8 pb-12">
          <div class="max-w-2xl">
            <h1 class="text-4xl md:text-5xl font-black text-brand-900 mb-6 leading-tight">
              Food Additives <span class="text-banned">Banned</span> in Japan
            </h1>
            <p class="text-lg text-brand-500 font-medium leading-relaxed italic">
              A comprehensive list of substances prohibited or not authorized for food use within Japan.
            </p>
          </div>
          
          <div class="flex items-center gap-6 bg-banned-bg p-8 rounded-3xl border border-banned-border shadow-sm">
            <div class="text-center">
              <div class="text-5xl font-black text-banned mb-1">{bannedInJapan.length}</div>
              <div class="text-[10px] font-black uppercase tracking-widest text-banned-text">Prohibited Additives</div>
            </div>
            <div class="h-12 w-px bg-banned-border"></div>
            <div class="text-4xl">🇯🇵</div>
          </div>
        </div>
      </div>
    </div>

    <div class="container space-y-12">
      <Disclaimer />

      <!-- Japan Regulatory Framework Card -->
      <section class="bg-white rounded-3xl p-8 border border-brand-100 shadow-sm overflow-hidden relative">
        <div class="absolute top-0 right-0 -mr-8 -mt-8 w-32 h-32 bg-brand-50 rounded-full blur-2xl pointer-events-none"></div>
        
        <h2 class="text-xl font-bold text-brand-900 mb-8 flex items-center gap-3 relative z-10">
          <span class="w-1.5 h-6 bg-accent rounded-full"></span>
          Japan Regulatory Framework
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 relative z-10">
          <div>
            <h4 class="text-[10px] font-black uppercase tracking-widest text-brand-400 mb-2">Authority</h4>
            <p class="text-sm text-brand-900 font-bold">Ministry of Health, Labour and Welfare (MHLW)</p>
          </div>
          <div>
            <h4 class="text-[10px] font-black uppercase tracking-widest text-brand-400 mb-2">Primary Legislation</h4>
            <p class="text-sm text-brand-900 font-bold">Food Sanitation Act</p>
          </div>
          <div>
            <h4 class="text-[10px] font-black uppercase tracking-widest text-brand-400 mb-2">Philosophy</h4>
            <p class="text-sm text-brand-900 font-bold">Designated Additives System</p>
          </div>
          <div>
            <h4 class="text-[10px] font-black uppercase tracking-widest text-brand-400 mb-2">Review Process</h4>
            <p class="text-sm text-brand-900 font-bold">FSC Scientific Assessment</p>
          </div>
        </div>
        
        <div class="mt-8 pt-8 border-t border-brand-50 text-sm text-brand-600 leading-relaxed max-w-4xl">
           Japan's <strong class="text-brand-900 italic">Food Sanitation Act</strong> prohibits the use of any food additive except those designated by the Minister of Health, Labour and Welfare as safe. The system distinguishes between "Designated Additives," "Existing Additives," and "Natural Flavoring Agents."
        </div>
      </section>

      <!-- Banned Additives Table -->
      {bannedInJapan.length > 0 ? (
        <section class="bg-white rounded-3xl overflow-hidden border border-brand-100 shadow-sm">
          <div class="p-8 border-b border-brand-50 bg-white">
            <h2 class="text-xl font-bold text-brand-900 flex items-center gap-3">
              <span class="w-1.5 h-6 bg-banned rounded-full"></span>
              Prohibited Substances List
            </h2>
          </div>
          
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-brand-50/50">
                  <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-brand-400">Additive Name / E-Number</th>
                  <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-brand-400">Functional Class</th>
                  <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-brand-400 text-center">🇪🇺 EU</th>
                  <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-brand-400 text-center">🇺🇸 USA</th>
                  <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-brand-400 text-center">🇨🇦 CAN</th>
                  <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-brand-400 text-center">🇦🇺 AU/NZ</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-brand-50">
                {bannedInJapan.map((additive: any) => (
                  <tr class="group hover:bg-brand-50/30 transition-colors">
                    <td class="px-8 py-5">
                      <a href={`/additive/${additive.slug}/`} class="text-brand-900 font-bold hover:text-accent transition-colors underline decoration-brand-200 decoration-2 underline-offset-4">
                        {additive.names.common_name}
                      </a>
                      <div class="text-[10px] font-bold text-brand-400 mt-1 uppercase tracking-tighter">{additive.names.e_number}</div>
                    </td>
                    <td class="px-8 py-5 text-xs font-bold text-brand-500 uppercase tracking-tight">{additive.classification.functional_class}</td>
                    
                    <td class="px-4 py-5 text-center">
                      <span class={`inline-block px-2 py-0.5 text-[10px] font-black uppercase tracking-tighter rounded border ${
                        additive.regulations.eu.status === 'approved' ? 'bg-approved-bg text-approved-text border-approved-border' :
                        additive.regulations.eu.status === 'banned' ? 'bg-banned-bg text-banned-text border-banned-border' :
                        'bg-brand-100 text-brand-400 border-brand-200'
                      }`}>
                        {additive.regulations.eu.status}
                      </span>
                    </td>
                    <td class="px-4 py-5 text-center">
                      <span class={`inline-block px-2 py-0.5 text-[10px] font-black uppercase tracking-tighter rounded border ${
                        additive.regulations.usa.status === 'approved' ? 'bg-approved-bg text-approved-text border-approved-border' :
                        additive.regulations.usa.status === 'banned' ? 'bg-banned-bg text-banned-text border-banned-border' :
                        'bg-brand-100 text-brand-400 border-brand-200'
                      }`}>
                        {additive.regulations.usa.status}
                      </span>
                    </td>
                    <td class="px-4 py-5 text-center">
                      <span class={`inline-block px-2 py-0.5 text-[10px] font-black uppercase tracking-tighter rounded border ${
                        additive.regulations.canada.status === 'approved' ? 'bg-approved-bg text-approved-text border-approved-border' :
                        additive.regulations.canada.status === 'banned' ? 'bg-banned-bg text-banned-text border-banned-border' :
                        'bg-brand-100 text-brand-400 border-brand-200'
                      }`}>
                        {additive.regulations.canada.status}
                      </span>
                    </td>
                    <td class="px-4 py-5 text-center">
                      <span class={`inline-block px-2 py-0.5 text-[10px] font-black uppercase tracking-tighter rounded border ${
                        additive.regulations.australia_nz.status === 'approved' ? 'bg-approved-bg text-approved-text border-approved-border' :
                        additive.regulations.australia_nz.status === 'banned' ? 'bg-banned-bg text-banned-text border-banned-border' :
                        'bg-brand-100 text-brand-400 border-brand-200'
                      }`}>
                        {additive.regulations.australia_nz.status}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      ) : (
        <section class="bg-white rounded-3xl p-12 border border-brand-100 shadow-sm text-center">
          <p class="text-brand-500 font-medium italic">
            No additives in our database are currently flagged as "Banned" in Japan while being permitted elsewhere.
          </p>
        </section>
      )}

      <!-- Data Methodology Section -->
      <section class="bg-brand-900 rounded-3xl p-8 md:p-12 text-white overflow-hidden relative">
        <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 bg-banned/20 rounded-full blur-3xl pointer-events-none"></div>
        
        <h2 class="text-xl font-bold mb-8 flex items-center gap-3 relative z-10">
          <span class="w-1.5 h-6 bg-banned rounded-full"></span>
          Methodology & Data Sources
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 relative z-10">
          <div>
            <h4 class="text-[10px] font-black uppercase tracking-widest text-brand-400 mb-4">Official Sources</h4>
            <p class="text-xs text-brand-300 leading-relaxed font-medium">Primary data derived from the MHLW Food Additive Information and Japan Food Safety Commission (FSC) reports.</p>
          </div>
          <div>
            <h4 class="text-[10px] font-black uppercase tracking-widest text-brand-400 mb-4">Comparative Context</h4>
            <p class="text-xs text-brand-300 leading-relaxed font-medium">EU (Regulation 1333/2008), USA (FDA 21 CFR), Canada (Health Canada), and AU/NZ (FSANZ) regulations mapped for cross-reference.</p>
          </div>
          <div>
            <h4 class="text-[10px] font-black uppercase tracking-widest text-brand-400 mb-4">Update Frequency</h4>
            <p class="text-xs text-brand-300 leading-relaxed font-medium">Database snapshot current as of April 2026. This is not an exhaustive list of all substances.</p>
          </div>
        </div>
      </section>

    </div>
  </main>

  <Footer />
  <BreadcrumbSchema items={breadcrumbs} />
</BaseLayout>
