---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import RegulationStatusBadge from '../../components/RegulationStatusBadge.astro';
import FAQSchema from '../../components/FAQSchema.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

export async function getStaticPaths() {
  const additiveFiles = import.meta.glob('../../data/additives/*.json', { eager: true });
  const allAdditives = Object.values(additiveFiles) as any[];

  const paths = allAdditives.map((file: any) => {
    // Find related additives (same functional class, different slug)
    const relatedAdditives = allAdditives.filter((other: any) =>
      other.classification?.functional_class === file.classification?.functional_class &&
      other.slug !== file.slug
    ).slice(0, 5);

    return {
      params: { slug: file.slug },
      props: {
        additive: file,
        relatedAdditives
      }
    };
  });

  return paths;
}

const { additive, relatedAdditives } = Astro.props;
const { names, classification, regulations, safety_evaluations, natural_occurrence, manufacturing, other_uses, food_categories_eu, research_links, commonly_found_in } = additive;

const title = `${names.common_name} (${names.e_number}) — Regulation Status by Country | Food Additive DB`;
const description = `${names.common_name} (${names.e_number}) regulation status in EU, USA, Japan, Australia/NZ, and Canada. ${classification.functional_class} additive. ADI: ${safety_evaluations.jecfa_adi || 'Not specified'}.`;

// Breadcrumb
const breadcrumbs = [
  { name: 'Home', url: 'https://food.matrix-db.com/' },
  { name: 'Additives', url: 'https://food.matrix-db.com/' },
  { name: `${names.common_name} (${names.e_number})`, url: `https://food.matrix-db.com/additive/${additive.slug}/` }
];

// Generate FAQs
const faqs = [];

// FAQ 1: Always include
faqs.push({
  question: `What is ${names.common_name} (${names.e_number})?`,
  answer: `${names.common_name} (${names.e_number}) is a ${classification.functional_class} used in food products. It is ${classification.sub_class} and ${classification.source_type}. ${natural_occurrence.description || ''}`
});

// FAQ 2: If banned/restricted anywhere
const bannedCountries = [];
if (regulations.eu.status === 'banned') bannedCountries.push('EU');
if (regulations.usa.status === 'banned') bannedCountries.push('USA');
if (regulations.japan.status === 'banned') bannedCountries.push('Japan');
if (regulations.canada.status === 'banned') bannedCountries.push('Canada');
if (regulations.australia_nz.status === 'banned') bannedCountries.push('Australia/NZ');

const restrictedCountries = [];
if (regulations.eu.status === 'restricted') restrictedCountries.push('EU');
if (regulations.usa.status === 'restricted') restrictedCountries.push('USA');
if (regulations.japan.status === 'restricted') restrictedCountries.push('Japan');

if (bannedCountries.length > 0 || restrictedCountries.length > 0) {
  let answer = '';
  if (bannedCountries.length > 0) {
    answer += `${names.common_name} is banned in ${bannedCountries.join(', ')}. `;
  }
  if (restrictedCountries.length > 0) {
    answer += `It has restricted use in ${restrictedCountries.join(', ')}. `;
  }
  answer += 'Regulatory status varies by country. Always check with your local food regulatory authority for current information.';
  faqs.push({
    question: `Is ${names.common_name} banned in any country?`,
    answer: answer
  });
}

// FAQ 3: If found in nature
if (natural_occurrence.found_in_nature && natural_occurrence.natural_sources && natural_occurrence.natural_sources.length > 0) {
  faqs.push({
    question: `Where is ${names.common_name} found naturally?`,
    answer: `${names.common_name} is naturally found in ${natural_occurrence.natural_sources.join(', ')}. ${natural_occurrence.description || ''}`
  });
}

// FAQ 4: If ADI exists
if (safety_evaluations.jecfa_adi && safety_evaluations.jecfa_adi !== 'Not specified') {
  faqs.push({
    question: `What is the ADI for ${names.common_name}?`,
    answer: `The Acceptable Daily Intake (ADI) for ${names.common_name} is ${safety_evaluations.jecfa_adi} as established by JECFA (Joint FAO/WHO Expert Committee on Food Additives). ADI represents the amount that can be consumed daily over a lifetime without appreciable health risk.`
  });
}

// FAQ 5: If food categories exist
if (food_categories_eu && food_categories_eu.length > 0) {
  const categories = food_categories_eu.map((cat: any) => cat.category_name).slice(0, 3).join(', ');
  faqs.push({
    question: `What foods contain ${names.common_name}?`,
    answer: `${names.common_name} is used in various food categories including ${categories}. It is used as a ${classification.functional_class} in these products.`
  });
}

// FAQ 6: If multiple aliases
if (names.aliases && names.aliases.length >= 2) {
  faqs.push({
    question: `Is ${names.common_name} the same as ${names.aliases[0]}?`,
    answer: `Yes, ${names.common_name} is also known as ${names.aliases.join(', ')}. These are different names for the same substance.`
  });
}
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="container mx-auto px-4 py-8">
    <div class="max-w-4xl mx-auto">
      <Disclaimer />

      <!-- Title -->
      <h1 class="text-4xl font-bold text-gray-900 mb-2">
        {names.common_name}
      </h1>
      <p class="text-xl text-gray-600 mb-6">
        {names.e_number} {names.ins_number && `| INS ${names.ins_number}`}
      </p>

      <!-- Names & Identifiers -->
      <section class="bg-white rounded-lg shadow-sm p-6 mb-6">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">Names & Identifiers</h2>
        <dl class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <dt class="text-sm font-medium text-gray-500">E Number</dt>
            <dd class="mt-1 text-base text-gray-900">{names.e_number}</dd>
          </div>
          {names.ins_number && (
            <div>
              <dt class="text-sm font-medium text-gray-500">INS Number</dt>
              <dd class="mt-1 text-base text-gray-900">{names.ins_number}</dd>
            </div>
          )}
          {names.cas_number && (
            <div>
              <dt class="text-sm font-medium text-gray-500">CAS Number</dt>
              <dd class="mt-1 text-base text-gray-900">{names.cas_number}</dd>
            </div>
          )}
          {names.scientific_name && (
            <div>
              <dt class="text-sm font-medium text-gray-500">Scientific Name</dt>
              <dd class="mt-1 text-base text-gray-900">{names.scientific_name}</dd>
            </div>
          )}
          {names.japanese_name && (
            <div>
              <dt class="text-sm font-medium text-gray-500">Japanese Name</dt>
              <dd class="mt-1 text-base text-gray-900">{names.japanese_name}</dd>
            </div>
          )}
          {names.aliases && names.aliases.length > 0 && (
            <div class="md:col-span-2">
              <dt class="text-sm font-medium text-gray-500">Also Known As</dt>
              <dd class="mt-1 text-base text-gray-900">{names.aliases.join(', ')}</dd>
            </div>
          )}
        </dl>
      </section>

      <!-- Regulation Status -->
      <section class="bg-white rounded-lg shadow-sm p-6 mb-6">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">Regulation Status by Country</h2>

        <div class="flex flex-wrap gap-3 mb-6">
          <RegulationStatusBadge status={regulations.eu.status} country="🇪🇺 EU" />
          <RegulationStatusBadge status={regulations.usa.status} country="🇺🇸 USA" />
          <RegulationStatusBadge status={regulations.japan.status} country="🇯🇵 Japan" />
          <RegulationStatusBadge status={regulations.australia_nz.status} country="🇦🇺 AU/NZ" />
          <RegulationStatusBadge status={regulations.canada.status} country="🇨🇦 Canada" />
        </div>

        <div class="space-y-4">
          <!-- EU -->
          <div class="border-l-4 border-primary-400 pl-4">
            <h3 class="font-semibold text-gray-900">European Union</h3>
            <p class="text-sm text-gray-600 mt-1">
              <strong>Status:</strong> {regulations.eu.status}
              {regulations.eu.max_level_mg_kg && ` | Max level: ${regulations.eu.max_level_mg_kg} mg/kg`}
            </p>
            {regulations.eu.conditions && (
              <p class="text-sm text-gray-600 mt-1">{regulations.eu.conditions}</p>
            )}
            {regulations.eu.efsa_opinion_url && (
              <a href={regulations.eu.efsa_opinion_url} target="_blank" rel="noopener" class="text-sm text-blue-600 hover:underline mt-1 inline-block">
                View EFSA Opinion →
              </a>
            )}
          </div>

          <!-- USA -->
          <div class="border-l-4 border-primary-400 pl-4">
            <h3 class="font-semibold text-gray-900">United States</h3>
            <p class="text-sm text-gray-600 mt-1">
              <strong>Status:</strong> {regulations.usa.status}
              {regulations.usa.classification && ` | ${regulations.usa.classification}`}
            </p>
            {regulations.usa.notes && (
              <p class="text-sm text-gray-600 mt-1">{regulations.usa.notes}</p>
            )}
          </div>

          <!-- Japan -->
          <div class="border-l-4 border-primary-400 pl-4">
            <h3 class="font-semibold text-gray-900">Japan</h3>
            <p class="text-sm text-gray-600 mt-1">
              <strong>Status:</strong> {regulations.japan.status}
              {regulations.japan.category && ` | Category: ${regulations.japan.category}`}
            </p>
            {regulations.japan.notes && (
              <p class="text-sm text-gray-600 mt-1">{regulations.japan.notes}</p>
            )}
          </div>

          <!-- Australia/NZ -->
          <div class="border-l-4 border-primary-400 pl-4">
            <h3 class="font-semibold text-gray-900">Australia / New Zealand</h3>
            <p class="text-sm text-gray-600 mt-1">
              <strong>Status:</strong> {regulations.australia_nz.status}
              {regulations.australia_nz.code && ` | Code: ${regulations.australia_nz.code}`}
            </p>
            {regulations.australia_nz.notes && (
              <p class="text-sm text-gray-600 mt-1">{regulations.australia_nz.notes}</p>
            )}
          </div>

          <!-- Canada -->
          <div class="border-l-4 border-primary-400 pl-4">
            <h3 class="font-semibold text-gray-900">Canada</h3>
            <p class="text-sm text-gray-600 mt-1">
              <strong>Status:</strong> {regulations.canada.status}
            </p>
            {regulations.canada.notes && (
              <p class="text-sm text-gray-600 mt-1">{regulations.canada.notes}</p>
            )}
          </div>
        </div>
      </section>

      <!-- What is it? -->
      <section class="bg-white rounded-lg shadow-sm p-6 mb-6">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">What is {names.common_name}?</h2>

        <div class="prose max-w-none">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Classification</h3>
          <p class="text-gray-700 mb-4">
            <strong>Function:</strong> {classification.functional_class}<br/>
            <strong>Type:</strong> {classification.sub_class}<br/>
            <strong>Source:</strong> {classification.source_type}
          </p>

          {natural_occurrence.found_in_nature && (
            <>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">Natural Occurrence</h3>
              <p class="text-gray-700 mb-2">{natural_occurrence.description}</p>
              {natural_occurrence.natural_sources && natural_occurrence.natural_sources.length > 0 && (
                <p class="text-gray-700 mb-4">
                  <strong>Found in:</strong> {natural_occurrence.natural_sources.join(', ')}
                </p>
              )}
            </>
          )}

          <h3 class="text-lg font-semibold text-gray-900 mb-2">How It's Made</h3>
          <p class="text-gray-700 mb-4">
            <strong>Method:</strong> {manufacturing.method}<br/>
            {manufacturing.description}
          </p>

          {(other_uses.cosmetics || other_uses.industrial || other_uses.pharmaceutical || other_uses.household) && (
            <>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">Uses Beyond Food</h3>
              <ul class="list-disc pl-5 text-gray-700">
                {other_uses.cosmetics && <li><strong>Cosmetics:</strong> {other_uses.cosmetics}</li>}
                {other_uses.pharmaceutical && <li><strong>Pharmaceutical:</strong> {other_uses.pharmaceutical}</li>}
                {other_uses.industrial && <li><strong>Industrial:</strong> {other_uses.industrial}</li>}
                {other_uses.household && <li><strong>Household:</strong> {other_uses.household}</li>}
              </ul>
            </>
          )}
        </div>
      </section>

      <!-- Commonly Found In -->
      {commonly_found_in && commonly_found_in.length > 0 && (
        <section class="bg-white rounded-lg shadow-sm p-6 mb-6">
          <h2 class="text-2xl font-semibold text-gray-900 mb-4">Commonly Found In</h2>
          <p class="text-sm text-gray-600 mb-4">
            {names.common_name} is typically used in:
          </p>
          <div class="flex flex-wrap gap-2">
            {commonly_found_in.map((product: string) => (
              <span class="inline-flex items-center px-3 py-2 bg-gray-100 text-gray-800 rounded-lg text-sm">
                <svg class="w-4 h-4 mr-2 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
                {product}
              </span>
            ))}
          </div>
          <p class="text-xs text-gray-500 mt-4">
            Note: This list shows typical product categories and may vary by brand and region. Always check product labels for actual ingredients.
          </p>
        </section>
      )}

      <!-- Safety Evaluations -->
      <section class="bg-white rounded-lg shadow-sm p-6 mb-6">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">Safety Evaluations (Official)</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">JECFA (WHO/FAO)</h3>
            <p class="text-sm text-gray-700">
              <strong>ADI:</strong> {safety_evaluations.jecfa_adi || 'Not specified'}<br/>
              {safety_evaluations.jecfa_evaluation_year && (
                <>Evaluated: {safety_evaluations.jecfa_evaluation_year}</>
              )}
            </p>
            {safety_evaluations.jecfa_url && (
              <a href={safety_evaluations.jecfa_url} target="_blank" rel="noopener" class="text-sm text-blue-600 hover:underline mt-2 inline-block">
                View JECFA Database →
              </a>
            )}
          </div>

          <div>
            <h3 class="font-semibold text-gray-900 mb-2">EFSA (EU)</h3>
            <p class="text-sm text-gray-700">
              <strong>ADI:</strong> {safety_evaluations.efsa_adi || 'Not specified'}<br/>
              {safety_evaluations.efsa_evaluation_year && (
                <>Evaluated: {safety_evaluations.efsa_evaluation_year}</>
              )}
            </p>
            {safety_evaluations.efsa_opinion_url && (
              <a href={safety_evaluations.efsa_opinion_url} target="_blank" rel="noopener" class="text-sm text-blue-600 hover:underline mt-2 inline-block">
                View EFSA Opinion →
              </a>
            )}
          </div>
        </div>

        <p class="text-xs text-gray-500 mt-4">
          ADI = Acceptable Daily Intake (mg per kg of body weight per day)
        </p>
      </section>

      <!-- Research & Official Documents -->
      <section class="bg-white rounded-lg shadow-sm p-6 mb-6">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">Research & Official Documents</h2>

        <div class="space-y-3">
          <p class="text-sm text-gray-700 mb-4">
            Official evaluations and scientific research:
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {research_links.efsa_opinion_url && (
              <a
                href={research_links.efsa_opinion_url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center p-3 border border-gray-200 rounded-lg hover:border-primary-400 hover:bg-primary-50 transition-colors"
              >
                <svg class="w-5 h-5 mr-2 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                <div>
                  <div class="font-medium text-gray-900">EFSA Scientific Opinion</div>
                  <div class="text-xs text-gray-600">European Food Safety Authority</div>
                </div>
              </a>
            )}

            {research_links.jecfa_url && (
              <a
                href={research_links.jecfa_url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center p-3 border border-gray-200 rounded-lg hover:border-primary-400 hover:bg-primary-50 transition-colors"
              >
                <svg class="w-5 h-5 mr-2 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                <div>
                  <div class="font-medium text-gray-900">JECFA Evaluation</div>
                  <div class="text-xs text-gray-600">WHO/FAO Expert Committee</div>
                </div>
              </a>
            )}

            {research_links.fda_cfr_url && (
              <a
                href={research_links.fda_cfr_url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center p-3 border border-gray-200 rounded-lg hover:border-primary-400 hover:bg-primary-50 transition-colors"
              >
                <svg class="w-5 h-5 mr-2 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                <div>
                  <div class="font-medium text-gray-900">FDA CFR Reference</div>
                  <div class="text-xs text-gray-600">Code of Federal Regulations</div>
                </div>
              </a>
            )}

            {research_links.codex_url && (
              <a
                href={research_links.codex_url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center p-3 border border-gray-200 rounded-lg hover:border-primary-400 hover:bg-primary-50 transition-colors"
              >
                <svg class="w-5 h-5 mr-2 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                <div>
                  <div class="font-medium text-gray-900">Codex Alimentarius</div>
                  <div class="text-xs text-gray-600">International Food Standards</div>
                </div>
              </a>
            )}
          </div>

          <div class="mt-6 pt-6 border-t border-gray-200">
            <p class="text-sm font-medium text-gray-700 mb-3">Search research databases:</p>
            <div class="flex flex-wrap gap-3">
              {research_links.pubmed_search_url && (
                <a
                  href={research_links.pubmed_search_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-primary-100 hover:text-primary-700 transition-colors text-sm"
                >
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                  </svg>
                  Search PubMed
                </a>
              )}
              {research_links.google_scholar_url && (
                <a
                  href={research_links.google_scholar_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-primary-100 hover:text-primary-700 transition-colors text-sm"
                >
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                  </svg>
                  Search Google Scholar
                </a>
              )}
            </div>
          </div>
        </div>
      </section>

      <!-- FAQ Section -->
      {faqs.length > 0 && (
        <section class="bg-white rounded-lg shadow-sm p-6 mb-6">
          <h2 class="text-2xl font-semibold text-gray-900 mb-4">Frequently Asked Questions</h2>

          <div class="space-y-6">
            {faqs.map((faq, index) => (
              <div key={index}>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">{faq.question}</h3>
                <p class="text-gray-700">{faq.answer}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Related Additives -->
      {relatedAdditives && relatedAdditives.length > 0 && (
        <section class="bg-gray-50 rounded-lg p-6 mb-6">
          <h2 class="text-2xl font-semibold text-gray-900 mb-4">Related Additives</h2>
          <p class="text-sm text-gray-600 mb-4">
            Other {classification.functional_class}s in our database:
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {relatedAdditives.map((related: any) => {
              const hasBan = related.regulations?.eu?.status === 'banned' ||
                            related.regulations?.usa?.status === 'banned' ||
                            related.regulations?.japan?.status === 'banned';

              return (
                <a
                  href={`/additive/${related.slug}/`}
                  class="block p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-400 hover:shadow-md transition-all"
                >
                  <div class="flex items-start justify-between mb-2">
                    <div class="flex-1">
                      <div class="font-semibold text-gray-900">{related.names?.common_name}</div>
                      <div class="text-sm text-gray-600">{related.names?.e_number}</div>
                    </div>
                    {hasBan && (
                      <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-danger-100 text-danger-800 ml-2">
                        Banned
                      </span>
                    )}
                  </div>
                  {related.names?.aliases && related.names.aliases.length > 0 && (
                    <div class="text-xs text-gray-500 mt-1">
                      {related.names.aliases[0]}
                    </div>
                  )}
                </a>
              );
            })}
          </div>
        </section>
      )}
    </div>
  </main>

  <Footer />
  <FAQSchema faqs={faqs} />
  <BreadcrumbSchema items={breadcrumbs} />
</BaseLayout>
