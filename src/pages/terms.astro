---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Terms of Use | Food Additive Regulation Database"
  description="Terms of use for the Food Additive Regulation Database."
>
  <Header />

  <main class="container mx-auto px-4 py-8">
    <div class="max-w-3xl mx-auto prose prose-lg">
      <h1>Terms of Use</h1>
      <p class="text-sm text-gray-600">Last updated: April 3, 2026</p>

      <h2>Acceptance of Terms</h2>
      <p>
        By accessing and using food.matrix-db.com (the "Site"), you accept and agree to be bound by these Terms of Use.
      </p>

      <h2>Nature of Information</h2>

      <h3>Informational Purpose Only</h3>
      <p>
        The Food Additive Regulation Database provides factual regulatory information compiled from official government sources. <strong>This information is for informational purposes only and does NOT constitute:</strong>
      </p>
      <ul>
        <li>Medical advice</li>
        <li>Nutritional advice</li>
        <li>Safety recommendations</li>
        <li>Professional guidance of any kind</li>
      </ul>

      <h3>Not a Substitute for Official Sources</h3>
      <p>
        <strong>Always verify information with official regulatory authorities.</strong> Regulatory status can change, and you should refer to:
      </p>
      <ul>
        <li>Your local food regulatory authority</li>
        <li>Official government publications</li>
        <li>Qualified professionals (dietitians, food scientists, etc.)</li>
