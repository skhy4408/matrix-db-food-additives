---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import TimelineView from '../../components/TimelineView.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

export async function getStaticPaths() {
  const historyFiles = import.meta.glob('../../data/regulatory-history/*.json', { eager: true });
  const additiveFiles = import.meta.glob('../../data/additives/*.json', { eager: true });

  // Create additive map for quick lookup
  const additiveMap = Object.values(additiveFiles).reduce((acc, file: any) => {
    acc[file.slug] = file;
    return acc;
  }, {} as Record<string, any>);

  const paths = Object.values(historyFiles).map((file: any) => {
    const additive = additiveMap[file.additive_slug];

    return {
      params: { slug: file.slug },
      props: {
        history: file,
        additive: additive
      }
    };
  });

  return paths;
}

const { history, additive } = Astro.props;

const title = `${additive.names.common_name} (${additive.names.e_number}) — Regulatory History Timeline | Food Additive DB`;
const description = `Complete timeline of regulatory events, safety evaluations, and approvals/bans for ${additive.names.common_name} (${additive.names.e_number}). ${history.events.length} documented events from regulatory agencies worldwide.`;

// Breadcrumb
const breadcrumbs = [
  { name: 'Home', url: 'https://food.matrix-db.com/' },
  { name: 'Additives', url: 'https://food.matrix-db.com/' },
  { name: `${additive.names.common_name} (${additive.names.e_number})`, url: `https://food.matrix-db.com/additive/${additive.slug}/` },
  { name: 'Regulatory Timeline', url: `https://food.matrix-db.com/timeline/${history.slug}/` }
];
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="bg-brand-50 pb-20">
    <!-- Hero & Breadcrumbs -->
    <div class="bg-white border-b border-brand-100 mb-12">
      <div class="container py-4">
        <nav class="flex text-xs font-semibold uppercase tracking-wider text-brand-400 mb-8">
          <a href="/" class="hover:text-accent transition-colors">Home</a>
          <span class="mx-2">/</span>
          <a href={`/additive/${additive.slug}/`} class="hover:text-accent transition-colors">{additive.names.e_number}</a>
          <span class="mx-2">/</span>
          <span class="text-brand-900 uppercase">Regulatory Timeline</span>
        </nav>

        <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 pb-12">
          <div class="max-w-3xl">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent/10 border border-accent/20 text-accent text-[10px] font-black uppercase tracking-widest mb-6">
              Chronological Evidence
            </div>
            <h1 class="text-4xl md:text-5xl font-black text-brand-900 mb-4 leading-tight">
              Regulatory History: <span class="text-accent">{additive.names.common_name}</span>
            </h1>
            <p class="text-lg text-brand-500 font-medium leading-relaxed italic">
              Tracking global safety evaluations, classification changes, and regional status updates for {additive.names.e_number}.
            </p>
          </div>
          
          <div class="flex flex-col gap-2 min-w-[160px]">
            <span class="text-[10px] uppercase tracking-widest font-bold text-brand-400">Total Events</span>
            <div class="bg-brand-900 text-white rounded-2xl p-4 shadow-lg shadow-brand-900/20 text-center">
              <div class="text-3xl font-black leading-none">{history.events.length}</div>
              <div class="text-[10px] uppercase tracking-widest font-bold text-brand-400 mt-1">Documented</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="container max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        
        <!-- Main Timeline -->
        <div class="lg:col-span-8 space-y-12">
          <Disclaimer />

          <section class="bg-white rounded-3xl p-8 md:p-12 shadow-sm border border-brand-100">
            <h2 class="text-xl font-bold text-brand-900 mb-12 flex items-center gap-3">
              <span class="w-1.5 h-6 bg-accent rounded-full"></span>
              Comprehensive Timeline
            </h2>
            
            <TimelineView events={history.events} compact={false} />
          </section>

          <!-- Navigation Back -->
          <div class="pt-8 border-t border-brand-100 flex justify-center">
            <a href={`/additive/${additive.slug}/`} class="inline-flex items-center gap-3 px-8 py-4 bg-brand-900 hover:bg-black text-white rounded-2xl font-bold transition-all shadow-xl shadow-brand-900/20 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform"><path d="m15 18-6-6 6-6"/></svg>
              Back to {additive.names.common_name} Profile
            </a>
          </div>
        </div>

        <!-- Sidebar Info -->
        <aside class="lg:col-span-4 space-y-6 lg:sticky lg:top-24">
          <div class="bg-white rounded-3xl p-8 border border-brand-100 shadow-sm">
            <h3 class="text-sm font-black uppercase tracking-widest text-brand-900 mb-6 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
              About This Log
            </h3>
            <div class="space-y-6">
              <p class="text-sm text-brand-600 leading-relaxed font-medium">
                This chronological record captures major regulatory shifts including approvals, bans, and safety re-assessments by agencies like EFSA, FDA, and JECFA.
              </p>
              <div class="pt-6 border-t border-brand-50 space-y-4">
                <div class="flex items-start gap-3">
                  <div class="w-1.5 h-1.5 rounded-full bg-brand-300 mt-1.5"></div>
                  <p class="text-xs text-brand-500 leading-relaxed italic">Regulatory decisions reflect scientific knowledge at the time of publication.</p>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-1.5 h-1.5 rounded-full bg-brand-300 mt-1.5"></div>
                  <p class="text-xs text-brand-500 leading-relaxed italic">Historical data may not reflect current national laws.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-brand-100 rounded-3xl p-8 border border-brand-200">
            <h3 class="text-[10px] font-black uppercase tracking-widest text-brand-400 mb-4">Official Sources</h3>
            <div class="space-y-3">
              <div class="p-3 bg-white rounded-xl border border-brand-200 flex items-center gap-3">
                <div class="text-lg">🇪🇺</div>
                <div class="text-xs font-bold text-brand-900">EFSA Opinions</div>
              </div>
              <div class="p-3 bg-white rounded-xl border border-brand-200 flex items-center gap-3">
                <div class="text-lg">🇺🇸</div>
                <div class="text-xs font-bold text-brand-900">FDA GRAS Notices</div>
              </div>
              <div class="p-3 bg-white rounded-xl border border-brand-200 flex items-center gap-3">
                <div class="text-lg">🌐</div>
                <div class="text-xs font-bold text-brand-900">JECFA Monographs</div>
              </div>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </main>

  <Footer />
  <BreadcrumbSchema items={breadcrumbs} />
</BaseLayout>
