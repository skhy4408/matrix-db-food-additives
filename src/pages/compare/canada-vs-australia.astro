---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

// Load all additives
const additiveFiles = import.meta.glob('../../data/additives/*.json', { eager: true });
const allAdditives = Object.values(additiveFiles) as any[];

// Compare Canada vs Australia/NZ
const comparison = {
  canadaOnly: allAdditives.filter(a => a.regulations.canada.status === 'approved' && a.regulations.australia_nz.status === 'banned'),
  australiaOnly: allAdditives.filter(a => a.regulations.australia_nz.status === 'approved' && a.regulations.canada.status === 'banned'),
  bothApproved: allAdditives.filter(a => a.regulations.canada.status === 'approved' && a.regulations.australia_nz.status === 'approved'),
  bothBanned: allAdditives.filter(a => a.regulations.canada.status === 'banned' && a.regulations.australia_nz.status === 'banned'),
  differences: allAdditives.filter(a => {
    const caStatus = a.regulations.canada.status;
    const auStatus = a.regulations.australia_nz.status;
    return (caStatus === 'approved' && auStatus === 'banned') ||
           (caStatus === 'banned' && auStatus === 'approved') ||
           (caStatus === 'restricted' && auStatus === 'approved') ||
           (caStatus === 'approved' && auStatus === 'restricted');
  })
};

const title = 'Canada vs Australia/NZ Food Additive Regulations Comparison | Food Additive DB';
const description = `Compare food additive regulations between Canada and Australia/New Zealand. ${comparison.differences.length} additives with different regulatory status.`;

const breadcrumbs = [
  { name: 'Home', url: 'https://food.matrix-db.com/' },
  { name: 'Country Comparisons', url: 'https://food.matrix-db.com/' },
  { name: 'Canada vs Australia/NZ', url: 'https://food.matrix-db.com/compare/canada-vs-australia/' }
];
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="bg-brand-50 pb-20">
    <!-- Hero & Breadcrumbs -->
    <div class="bg-white border-b border-brand-100 mb-12">
      <div class="container py-4">
        <nav class="flex text-xs font-semibold uppercase tracking-wider text-brand-400 mb-8">
          <a href="/" class="hover:text-accent">Home</a>
          <span class="mx-2">/</span>
          <span class="text-brand-900 uppercase">Comparisons</span>
          <span class="mx-2">/</span>
          <span class="text-accent uppercase">Canada vs AU/NZ</span>
        </nav>

        <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-12 pb-12">
          <div class="max-w-2xl">
            <h1 class="text-4xl md:text-5xl font-black text-brand-900 mb-6 leading-tight">
              <span class="text-accent">Canada vs AU/NZ:</span> Food Additive Regulations
            </h1>
            <p class="text-lg text-brand-500 font-medium leading-relaxed italic">
              Comparing Commonwealth standards: Health Canada's risk-based framework versus the joint FSANZ (Food Standards Australia New Zealand) system.
            </p>
          </div>
          
          <div class="flex items-center gap-4 bg-brand-50 p-6 rounded-3xl border border-brand-100 shadow-sm">
            <div class="text-center">
              <div class="text-4xl mb-2">🇨🇦</div>
              <div class="text-[10px] font-black uppercase tracking-widest text-brand-900">Canada</div>
            </div>
            <div class="h-12 w-px bg-brand-200"></div>
            <div class="text-center px-4">
              <div class="text-xl font-black text-accent">VS</div>
            </div>
            <div class="h-12 w-px bg-brand-200"></div>
            <div class="text-center">
              <div class="text-4xl mb-2">🇦🇺</div>
              <div class="text-[10px] font-black uppercase tracking-widest text-brand-900">AU / NZ</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="container space-y-12">
      <!-- Quick Stats -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { label: 'Regulatory Gaps', val: comparison.differences.length, color: 'text-accent', bg: 'bg-white' },
          { label: 'Harmonized', val: comparison.bothApproved.length, color: 'text-approved', bg: 'bg-white' },
          { label: 'Canada Exclusive', val: comparison.canadaOnly.length, color: 'text-red-600', bg: 'bg-white' },
          { label: 'AU/NZ Exclusive', val: comparison.australiaOnly.length, color: 'text-blue-600', bg: 'bg-white' },
        ].map(stat => (
          <div class={`${stat.bg} p-8 rounded-3xl border border-brand-100 shadow-sm text-center transform hover:-translate-y-1 transition-transform`}>
            <div class={`text-4xl font-black mb-2 ${stat.color}`}>{stat.val}</div>
            <div class="text-[10px] font-black uppercase tracking-widest text-brand-400">{stat.label}</div>
          </div>
        ))}
      </div>

      <Disclaimer />

      <!-- Authorities Side-by-Side -->
      <section class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Canada -->
        <div class="bg-white rounded-3xl p-8 border border-brand-100 shadow-sm">
          <div class="flex items-center gap-4 mb-8">
            <div class="text-3xl">🇨🇦</div>
            <h2 class="text-xl font-bold text-brand-900 uppercase tracking-tight">Canadian Standards</h2>
          </div>
          <div class="space-y-6">
            <div class="pb-6 border-b border-brand-50">
              <h3 class="text-[10px] font-black uppercase tracking-widest text-brand-400 mb-2">Primary Authority</h3>
              <p class="text-brand-900 font-bold">Health Canada (Food Directorate)</p>
            </div>
            <div class="pb-6 border-b border-brand-50">
              <h3 class="text-[10px] font-black uppercase tracking-widest text-brand-400 mb-2">Philosophical Approach</h3>
              <p class="text-sm text-brand-600 leading-relaxed"><strong class="text-brand-900 italic">Pre-Market Approval:</strong> Additives must be safe for use, have a proven technological purpose, and be listed on Health Canada's specific "Lists of Permitted Food Additives."</p>
            </div>
            <div>
              <h3 class="text-[10px] font-black uppercase tracking-widest text-brand-400 mb-2">System</h3>
              <p class="text-sm text-brand-900 font-bold uppercase tracking-tight">Food and Drug Regulations (FDR)</p>
            </div>
          </div>
        </div>

        <!-- Australia/NZ -->
        <div class="bg-white rounded-3xl p-8 border border-brand-100 shadow-sm">
          <div class="flex items-center gap-4 mb-8">
            <div class="text-3xl">🇦🇺</div>
            <h2 class="text-xl font-bold text-brand-900 uppercase tracking-tight">Australia & NZ Standards</h2>
          </div>
          <div class="space-y-6">
            <div class="pb-6 border-b border-brand-50">
              <h3 class="text-[10px] font-black uppercase tracking-widest text-brand-400 mb-2">Primary Authority</h3>
              <p class="text-brand-900 font-bold">Food Standards Australia New Zealand (FSANZ)</p>
            </div>
            <div class="pb-6 border-b border-brand-50">
              <h3 class="text-[10px] font-black uppercase tracking-widest text-brand-400 mb-2">Philosophical Approach</h3>
              <p class="text-sm text-brand-600 leading-relaxed"><strong class="text-brand-900 italic">Science-Based Risk Assessment:</strong> Rigorous pre-market assessment for all new additives. Emphasis on protecting public health and providing adequate information for consumers.</p>
            </div>
            <div>
              <h3 class="text-[10px] font-black uppercase tracking-widest text-brand-400 mb-2">System</h3>
              <p class="text-sm text-brand-900 font-bold uppercase tracking-tight">ANZ Food Standards Code (Standard 1.3.1)</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Comparison Table -->
      <section class="bg-white rounded-3xl overflow-hidden border border-brand-100 shadow-sm">
        <div class="p-8 border-b border-brand-50">
          <h2 class="text-xl font-bold text-brand-900 flex items-center gap-3">
            <span class="w-1.5 h-6 bg-accent rounded-full"></span>
            Additives with Different Regulatory Status
          </h2>
        </div>
        
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-brand-50/50">
                <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-brand-400">Chemical / E-Number</th>
                <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-brand-400">Function</th>
                <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-brand-400 text-center">🇨🇦 Canada Status</th>
                <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-brand-400 text-center">🇦🇺 AU/NZ Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-brand-50">
              {comparison.differences.map((additive: any) => (
                <tr class="group hover:bg-brand-50/30 transition-colors">
                  <td class="px-8 py-5">
                    <a href={`/additive/${additive.slug}/`} class="text-brand-900 font-bold hover:text-accent transition-colors underline decoration-brand-200 decoration-2 underline-offset-4">
                      {additive.names.common_name}
                    </a>
                    <div class="text-[10px] font-bold text-brand-400 mt-1 uppercase tracking-tighter">{additive.names.e_number}</div>
                  </td>
                  <td class="px-8 py-5 text-xs font-bold text-brand-500 uppercase tracking-tight">{additive.classification.functional_class}</td>
                  <td class="px-8 py-5 text-center">
                    <span class={`inline-block px-3 py-1 text-[10px] font-black uppercase tracking-widest rounded-lg border shadow-sm ${
                      additive.regulations.canada.status === 'approved' ? 'bg-approved-bg text-approved-text border-approved-border' :
                      additive.regulations.canada.status === 'banned' ? 'bg-banned-bg text-banned-text border-banned-border' :
                      'bg-restricted-bg text-restricted-text border-restricted-border'
                    }`}>
                      {additive.regulations.canada.status}
                    </span>
                  </td>
                  <td class="px-8 py-5 text-center">
                    <span class={`inline-block px-3 py-1 text-[10px] font-black uppercase tracking-widest rounded-lg border shadow-sm ${
                      additive.regulations.australia_nz.status === 'approved' ? 'bg-approved-bg text-approved-text border-approved-border' :
                      additive.regulations.australia_nz.status === 'banned' ? 'bg-banned-bg text-banned-text border-banned-border' :
                      'bg-restricted-bg text-restricted-text border-restricted-border'
                    }`}>
                      {additive.regulations.australia_nz.status}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- Notable Examples Highlighting -->
      <section class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {comparison.canadaOnly.length > 0 && (
          <div class="bg-white rounded-3xl p-8 border-t-4 border-red-600 shadow-sm">
            <h3 class="text-lg font-bold text-brand-900 mb-6 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-red-600"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
              Canada Approved, AU/NZ Banned
            </h3>
            <div class="flex flex-wrap gap-2">
              {comparison.canadaOnly.map((additive: any) => (
                <a href={`/additive/${additive.slug}/`} class="px-3 py-2 bg-red-50 text-red-800 rounded-xl hover:bg-red-100 text-xs font-bold border border-red-100 transition-colors">
                  {additive.names.common_name} <span class="opacity-50 ml-1">{additive.names.e_number}</span>
                </a>
              ))}
            </div>
          </div>
        )}

        {comparison.australiaOnly.length > 0 && (
          <div class="bg-white rounded-3xl p-8 border-t-4 border-blue-600 shadow-sm">
            <h3 class="text-lg font-bold text-brand-900 mb-6 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
              AU/NZ Approved, Canada Banned
            </h3>
            <div class="flex flex-wrap gap-2">
              {comparison.australiaOnly.map((additive: any) => (
                <a href={`/additive/${additive.slug}/`} class="px-3 py-2 bg-blue-50 text-blue-800 rounded-xl hover:bg-blue-100 text-xs font-bold border border-blue-100 transition-colors">
                  {additive.names.common_name} <span class="opacity-50 ml-1">{additive.names.e_number}</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </section>

      <!-- Sources -->
      <section class="bg-brand-900 rounded-3xl p-8 md:p-12 text-white overflow-hidden relative">
        <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 bg-accent/20 rounded-full blur-3xl pointer-events-none"></div>
        
        <h2 class="text-xl font-bold mb-8 flex items-center gap-3 relative z-10">
          <span class="w-1.5 h-6 bg-accent rounded-full"></span>
          Data Verification & Methodology
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 relative z-10">
          <div>
            <h4 class="text-[10px] font-black uppercase tracking-widest text-brand-400 mb-4">Canada Data</h4>
            <p class="text-xs text-brand-300 leading-relaxed font-medium">Verified against Health Canada's Lists of Permitted Food Additives and Food and Drug Regulations (FDR).</p>
          </div>
          <div>
            <h4 class="text-[10px] font-black uppercase tracking-widest text-brand-400 mb-4">AU/NZ Data</h4>
            <p class="text-xs text-brand-300 leading-relaxed font-medium">Verified against the Australia New Zealand Food Standards Code (Standard 1.3.1) via FSANZ.</p>
          </div>
          <div>
            <h4 class="text-[10px] font-black uppercase tracking-widest text-brand-400 mb-4">Timeline</h4>
            <p class="text-xs text-brand-300 leading-relaxed font-medium">Status current as of April 2026. Global regulations are subject to frequent updates.</p>
          </div>
          <div>
            <h4 class="text-[10px] font-black uppercase tracking-widest text-brand-400 mb-4">Scope</h4>
            <p class="text-xs text-brand-300 leading-relaxed font-medium italic">Informational only. This database is not a legal document or health advice.</p>
          </div>
        </div>
      </section>

    </div>
  </main>

  <Footer />
  <BreadcrumbSchema items={breadcrumbs} />
</BaseLayout>
