---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const additiveFiles = import.meta.glob('../../data/additives/*.json', { eager: true });
const allAdditives = Object.values(additiveFiles) as any[];

const comparison = {
  usaOnly: allAdditives.filter(a => a.regulations.usa.status === 'approved' && a.regulations.canada.status === 'banned'),
  canadaOnly: allAdditives.filter(a => a.regulations.canada.status === 'approved' && a.regulations.usa.status === 'banned'),
  bothApproved: allAdditives.filter(a => a.regulations.usa.status === 'approved' && a.regulations.canada.status === 'approved'),
  differences: allAdditives.filter(a => {
    const usaStatus = a.regulations.usa.status;
    const caStatus = a.regulations.canada.status;
    return (usaStatus === 'approved' && caStatus === 'banned') ||
           (usaStatus === 'banned' && caStatus === 'approved');
  })
};

const title = 'USA vs Canada Food Additive Regulations Comparison | Food Additive DB';
const description = `Compare food additive regulations between the United States and Canada. ${comparison.differences.length} additives with different regulatory status.`;

const breadcrumbs = [
  { name: 'Home', url: 'https://food.matrix-db.com/' },
  { name: 'Country Comparisons', url: 'https://food.matrix-db.com/' },
  { name: 'USA vs Canada', url: 'https://food.matrix-db.com/compare/usa-vs-canada/' }
];
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="container mx-auto px-4 py-8">
    <div class="max-w-6xl mx-auto">
      <Disclaimer />

      <h1 class="text-4xl font-bold text-gray-900 mb-2">
        USA vs Canada: Food Additive Regulations
      </h1>
      <p class="text-xl text-gray-600 mb-8">
        Comparing regulatory approaches between the United States and Canada
      </p>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-white rounded-lg shadow-sm p-6 text-center">
          <div class="text-3xl font-bold text-primary-600">{comparison.differences.length}</div>
          <div class="text-sm text-gray-600 mt-1">Different Status</div>
        </div>
        <div class="bg-white rounded-lg shadow-sm p-6 text-center">
          <div class="text-3xl font-bold text-green-600">{comparison.bothApproved.length}</div>
          <div class="text-sm text-gray-600 mt-1">Both Approved</div>
        </div>
        <div class="bg-white rounded-lg shadow-sm p-6 text-center">
          <div class="text-3xl font-bold text-blue-600">{comparison.usaOnly.length}</div>
          <div class="text-sm text-gray-600 mt-1">USA Only</div>
        </div>
        <div class="bg-white rounded-lg shadow-sm p-6 text-center">
          <div class="text-3xl font-bold text-orange-600">{comparison.canadaOnly.length}</div>
          <div class="text-sm text-gray-600 mt-1">Canada Only</div>
        </div>
      </div>

      <section class="bg-white rounded-lg shadow-sm p-6 mb-6">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">Regulatory Authorities</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <h3 class="font-semibold text-lg text-gray-900 mb-2">🇺🇸 United States</h3>
            <dl class="space-y-2 text-sm">
              <div>
                <dt class="font-medium text-gray-700">Authority:</dt>
                <dd class="text-gray-600">FDA (Food and Drug Administration)</dd>
              </div>
              <div>
                <dt class="font-medium text-gray-700">Framework:</dt>
                <dd class="text-gray-600">21 CFR - Code of Federal Regulations</dd>
              </div>
            </dl>
          </div>
          <div>
            <h3 class="font-semibold text-lg text-gray-900 mb-2">🇨🇦 Canada</h3>
            <dl class="space-y-2 text-sm">
              <div>
                <dt class="font-medium text-gray-700">Authority:</dt>
                <dd class="text-gray-600">Health Canada</dd>
              </div>
              <div>
                <dt class="font-medium text-gray-700">Framework:</dt>
                <dd class="text-gray-600">Food and Drug Regulations (FDR)</dd>
              </div>
            </dl>
          </div>
        </div>
      </section>

      {comparison.differences.length > 0 && (
        <section class="bg-white rounded-lg shadow-sm p-6 mb-6">
          <h2 class="text-2xl font-semibold text-gray-900 mb-4">Different Regulatory Status</h2>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Additive</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Class</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">🇺🇸 USA</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">🇨🇦 Canada</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                {comparison.differences.map((additive: any) => (
                  <tr class="hover:bg-gray-50">
                    <td class="px-4 py-3">
                      <a href={`/additive/${additive.slug}/`} class="text-blue-600 hover:underline font-medium">
                        {additive.names.common_name}
                      </a>
                      <div class="text-xs text-gray-500">{additive.names.e_number}</div>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-700">{additive.classification.functional_class}</td>
                    <td class="px-4 py-3 text-center">
                      <span class={`inline-block px-2 py-1 text-xs font-medium rounded ${
                        additive.regulations.usa.status === 'approved' ? 'bg-green-100 text-green-800' :
                        'bg-red-100 text-red-800'
                      }`}>
                        {additive.regulations.usa.status}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-center">
                      <span class={`inline-block px-2 py-1 text-xs font-medium rounded ${
                        additive.regulations.canada.status === 'approved' ? 'bg-green-100 text-green-800' :
                        'bg-red-100 text-red-800'
                      }`}>
                        {additive.regulations.canada.status}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )}

      <section class="bg-gray-50 border border-gray-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-3">Data Sources</h3>
        <ul class="space-y-2 text-sm text-gray-700">
          <li>• <strong>USA:</strong> 21 CFR, FDA Database</li>
          <li>• <strong>Canada:</strong> Health Canada Lists of Permitted Food Additives</li>
          <li>• Data as of April 2026</li>
        </ul>
      </section>
    </div>
  </main>

  <Footer />
  <BreadcrumbSchema items={breadcrumbs} />
</BaseLayout>
