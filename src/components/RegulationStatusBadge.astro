---
interface Props {
  status: 'approved' | 'banned' | 'restricted' | 'unverified';
  country: string;
}

const { status, country } = Astro.props;

const statusConfig = {
  approved: {
    bg: 'bg-approved-bg',
    text: 'text-approved-text',
    border: 'border-approved-border',
    dot: 'bg-approved'
  },
  banned: {
    bg: 'bg-banned-bg',
    text: 'text-banned-text',
    border: 'border-banned-border',
    dot: 'bg-banned'
  },
  restricted: {
    bg: 'bg-restricted-bg',
    text: 'text-restricted-text',
    border: 'border-restricted-border',
    dot: 'bg-restricted'
  },
  unverified: {
    bg: 'bg-unverified-bg',
    text: 'text-unverified-text',
    border: 'border-unverified-border',
    dot: 'bg-unverified'
  }
};

const config = statusConfig[status];
---

<div class={`inline-flex items-center gap-2 px-3 py-1.5 rounded-lg border ${config.bg} ${config.text} ${config.border} shadow-sm transition-all hover:shadow-md`}>
  <span class="text-xs font-bold uppercase tracking-wider border-r border-current/20 pr-2 mr-0.5">{country}</span>
  <span class="flex items-center gap-1.5 text-xs font-bold uppercase tracking-tight">
    <span class={`w-1.5 h-1.5 rounded-full ${config.dot}`}></span>
    {status}
  </span>
</div>
