---
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-900 text-brand-100 mt-20">
  <div class="container py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand Section -->
      <div class="space-y-4">
        <a href="/" class="flex flex-col">
          <span class="text-xl font-bold text-white leading-tight">Food Additive <span class="text-accent">DB</span></span>
          <span class="text-[10px] uppercase tracking-wider font-semibold text-brand-400">Regulation Comparison</span>
        </a>
        <p class="text-sm text-brand-300 leading-relaxed max-w-xs">
          Comprehensive database comparing food additive regulations across major regions. Empowering consumers with clear, scientific data.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-semibold text-white mb-6 text-sm uppercase tracking-wider">Resources</h3>
        <ul class="space-y-4 text-sm text-brand-300">
          <li><a href="/" class="hover:text-accent transition-colors">Home</a></li>
          <li><a href="/search" class="hover:text-accent transition-colors">Search Additives</a></li>
          <li><a href="/about" class="hover:text-accent transition-colors">About the Project</a></li>
        </ul>
      </div>

      <!-- Educational Guides -->
      <div>
        <h3 class="font-semibold text-white mb-6 text-sm uppercase tracking-wider">Guides</h3>
        <ul class="space-y-4 text-sm text-brand-300">
          <li><a href="/guides/what-are-e-numbers/" class="hover:text-accent transition-colors">What are E Numbers?</a></li>
          <li><a href="/guides/reading-food-labels/" class="hover:text-accent transition-colors">Reading Food Labels</a></li>
          <li><a href="/guides/natural-vs-synthetic/" class="hover:text-accent transition-colors">Natural vs Synthetic</a></li>
          <li><a href="/guides/artificial-colors/" class="hover:text-accent transition-colors">Artificial Colors</a></li>
        </ul>
      </div>

      <!-- Legal & Social -->
      <div>
        <h3 class="font-semibold text-white mb-6 text-sm uppercase tracking-wider">Legal</h3>
        <ul class="space-y-4 text-sm text-brand-300">
          <li><a href="/privacy-policy" class="hover:text-accent transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-accent transition-colors">Terms of Use</a></li>
        </ul>
      </div>
    </div>

    <!-- Matrix DB Family Section -->
    <div class="mt-16 pt-8 border-t border-brand-800">
      <div class="text-center mb-8">
        <h3 class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">Matrix DB Family</h3>
        <p class="text-xs text-brand-400 mb-6 max-w-xl mx-auto">
          Explore our other databases for comprehensive information across different domains
        </p>
        <div class="flex flex-wrap justify-center gap-6">
          <a href="https://visa.matrix-db.com" class="text-sm text-brand-300 hover:text-accent transition-colors">
            Visa Requirements DB
          </a>
          <a href="https://skincare.matrix-db.com" class="text-sm text-brand-300 hover:text-accent transition-colors">
            Skincare Ingredients DB
          </a>
          <a href="https://api.matrix-db.com" class="text-sm text-brand-300 hover:text-accent transition-colors">
            API Directory
          </a>
        </div>
      </div>
    </div>

    <!-- Copyright & Disclaimer Section -->
    <div class="mt-8 pt-8 border-t border-brand-800 flex flex-col items-center gap-6">
      <div class="text-center space-y-2">
        <p class="text-xs text-brand-400 max-w-2xl mx-auto leading-relaxed italic">
          Disclaimer: This database is for informational purposes only. While we strive for accuracy, regulations change. Always refer to official government sources for the most current information.
        </p>
        <p class="text-xs text-brand-500 mt-4">
          © {currentYear} Matrix DB. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>
