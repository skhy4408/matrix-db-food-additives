---
interface Event {
  year: number;
  month: number | null;
  agency: string;
  country: string;
  action: string;
  detail: string;
}

interface Props {
  events: Event[];
  compact?: boolean;
}

const { events, compact = false } = Astro.props;

const sortedEvents = [...events].sort((a, b) => {
  if (a.year !== b.year) return a.year - b.year;
  if (a.month === null) return -1;
  if (b.month === null) return 1;
  return a.month - b.month;
});

const getActionStyles = (action: string) => {
  const a = action.toLowerCase();
  if (a.includes('ban')) return 'bg-banned-bg text-banned-text border-banned-border';
  if (a.includes('approv')) return 'bg-approved-bg text-approved-text border-approved-border';
  if (a.includes('restrict') || a.includes('concern') || a.includes('investigat')) return 'bg-restricted-bg text-restricted-text border-restricted-border';
  if (a.includes('review') || a.includes('evaluat')) return 'bg-brand-50 text-brand-600 border-brand-200';
  return 'bg-brand-50 text-brand-600 border-brand-200';
};

const formatDate = (year: number, month: number | null) => {
  if (month === null) return `${year}`;
  const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  return `${monthNames[month - 1]} ${year}`;
};
---

<div class="relative pl-8 border-l-2 border-brand-100 space-y-12 ml-4 py-4">
  {sortedEvents.map((event, index) => (
    <div class="relative">
      {/* Timeline Dot */}
      <div class={`absolute -left-[41px] top-1.5 w-5 h-5 rounded-full border-4 border-white shadow-sm ring-2 ${event.action.toLowerCase().includes('ban') ? 'ring-banned bg-banned' : event.action.toLowerCase().includes('approv') ? 'ring-approved bg-approved' : 'ring-accent bg-accent'}`}></div>
      
      {/* Content */}
      <div class="flex flex-col gap-3">
        <div class="flex items-center flex-wrap gap-4">
          <time class="text-xs font-black uppercase tracking-widest text-brand-900 bg-white px-3 py-1 rounded-full border border-brand-100 shadow-sm">{formatDate(event.year, event.month)}</time>
          <span class={`px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-widest border ${getActionStyles(event.action)}`}>
            {event.action}
          </span>
        </div>
        
        <div class="space-y-2">
          {!compact && (
            <div class="flex items-center gap-2 text-xs font-bold text-brand-400 uppercase tracking-tight">
              <span>{event.agency}</span>
              {event.country && <span class="opacity-30">•</span>}
              {event.country && <span>{event.country}</span>}
            </div>
          )}
          <p class={`${compact ? 'text-xs leading-relaxed font-medium text-brand-600' : 'text-sm leading-relaxed font-medium text-brand-600'} max-w-2xl`}>
            {event.detail}
          </p>
        </div>
      </div>
    </div>
  ))}
</div>
