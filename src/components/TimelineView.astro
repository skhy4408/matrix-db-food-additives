---
interface Event {
  year: number;
  month: number | null;
  agency: string;
  country: string;
  action: string;
  detail: string;
}

interface Props {
  events: Event[];
  compact?: boolean;
}

const { events, compact = false } = Astro.props;

const sortedEvents = [...events].sort((a, b) => {
  if (a.year !== b.year) return a.year - b.year;
  if (a.month === null) return -1;
  if (b.month === null) return 1;
  return a.month - b.month;
});

const actionColors: Record<string, string> = {
  approved: 'bg-green-100 text-green-800 border-green-300',
  banned: 'bg-red-100 text-red-800 border-red-300',
  discovered: 'bg-blue-100 text-blue-800 border-blue-300',
  reviewed: 'bg-gray-100 text-gray-800 border-gray-300',
  're-evaluated': 'bg-gray-100 text-gray-800 border-gray-300',
  classification: 'bg-yellow-100 text-yellow-800 border-yellow-300',
  'safety concern': 'bg-orange-100 text-orange-800 border-orange-300',
  publication: 'bg-purple-100 text-purple-800 border-purple-300',
  studies: 'bg-indigo-100 text-indigo-800 border-indigo-300',
  'labeling requirement': 'bg-amber-100 text-amber-800 border-amber-300',
  commercialized: 'bg-teal-100 text-teal-800 border-teal-300',
  evaluated: 'bg-gray-100 text-gray-800 border-gray-300',
  'comprehensive review': 'bg-gray-100 text-gray-800 border-gray-300',
  'terminology review': 'bg-purple-100 text-purple-800 border-purple-300',
  'regulation published': 'bg-blue-100 text-blue-800 border-blue-300',
  'classification change': 'bg-yellow-100 text-yellow-800 border-yellow-300',
  survey: 'bg-indigo-100 text-indigo-800 border-indigo-300',
  investigation: 'bg-orange-100 text-orange-800 border-orange-300',
  'status unchanged': 'bg-gray-100 text-gray-800 border-gray-300',
  listed: 'bg-amber-100 text-amber-800 border-amber-300',
  'proposed legislation': 'bg-purple-100 text-purple-800 border-purple-300',
  clarification: 'bg-blue-100 text-blue-800 border-blue-300',
};

const getActionColor = (action: string) => {
  return actionColors[action.toLowerCase()] || 'bg-gray-100 text-gray-800 border-gray-300';
};

const formatDate = (year: number, month: number | null) => {
  if (month === null) return `${year}`;
  const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  return `${monthNames[month - 1]} ${year}`;
};
---

<div class="relative">
  {sortedEvents.map((event, index) => (
    <div class="flex gap-4 pb-8 last:pb-0">
      {/* Timeline line */}
      <div class="flex flex-col items-center">
        <div class={`w-3 h-3 rounded-full border-2 ${event.action.toLowerCase() === 'banned' ? 'bg-red-500 border-red-600' : event.action.toLowerCase() === 'approved' ? 'bg-green-500 border-green-600' : 'bg-blue-500 border-blue-600'} mt-1.5`}></div>
        {index < sortedEvents.length - 1 && (
          <div class="w-0.5 bg-gray-300 flex-1 min-h-[60px]"></div>
        )}
      </div>

      {/* Event content */}
      <div class="flex-1 pb-4">
        <div class="flex flex-wrap items-center gap-2 mb-2">
          <span class="font-semibold text-gray-900">{formatDate(event.year, event.month)}</span>
          <span class={`inline-block px-2 py-0.5 text-xs font-medium rounded border ${getActionColor(event.action)}`}>
            {event.action}
          </span>
        </div>

        {!compact && (
          <div class="text-sm text-gray-600 mb-1">
            <span class="font-medium">{event.agency}</span>
            {event.country && <span> • {event.country}</span>}
          </div>
        )}

        <p class={compact ? 'text-sm text-gray-700' : 'text-gray-700'}>{event.detail}</p>
      </div>
    </div>
  ))}
</div>
