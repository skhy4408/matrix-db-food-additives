  "natural_occurrence": {
    "found_in_nature": true,
    "natural_sources": [
      "Produced by Lactococcus lactis bacteria during fermentation"
    ],
    "description": "NATURAL preservative produced by 'good bacteria' (Lactococcus lactis) during fermentation. A 'bacteriocin' - literally a peptide made by bacteria to kill other bacteria. Works like a natural antibiotic but is NOT considered an antibiotic. Discovered in 1928 (same era as penicillin!) at a Nissan cheese factory in England. Named after the Latin 'Nisus'. Breaks down in stomach acid, so no impact on gut bacteria. One of the safest preservatives - made by the same bacteria used to make cheese."
  },
  "manufacturing": {
    "method": "natural fermentation",
    "description": "Produced by fermentation using Lactococcus lactis bacteria, then purified and concentrated for use as a food preservative."
  },
