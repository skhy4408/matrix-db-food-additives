  "natural_occurrence": {
    "found_in_nature": false,
    "natural_sources": [],
    "description": "Sodium potassium tartrate (Rochelle salt) does not occur naturally. It is synthesized from tartaric acid, which is naturally found in grapes and wine."
  },
  "manufacturing": {
    "method": "chemical synthesis",
    "description": "Produced by neutralizing tartaric acid with a mixture of sodium hydroxide and potassium hydroxide, or by combining sodium tartrate and potassium tartrate solutions. The product crystallizes as the tetrahydrate form. First prepared in 1675 by Pierre Seignette, a French apothecary in La Rochelle (hence the name Rochelle salt)."
  },
  "other_uses": {
    "cosmetics": "Buffering agent in formulations.",
    "industrial": "Component of Fehling's solution (chemical testing), silvering mirrors, piezoelectric crystals (historical use in early microphones and phonograph pickups).",
    "pharmaceutical": "Laxative (mild), component in effervescent formulations.",
    "household": "Ingredient in some cleaning products."
  },
