  "manufacturing": {
    "method": "extraction",
    "description": "Seeds of Cassia tora or Cassia occidentalis plants are dehulled to remove the outer coat. The endosperm is separated, ground, and extracted to produce cassia gum powder. The polysaccharide is then purified and standardized."
  },
