  "manufacturing": {
    "method": "chemical synthesis via sulfonation",
    "description": "Synthesized through sulfonation of aromatic amine intermediates derived from petroleum-based chemicals. The reaction produces a synthetic triarylmethane dye that appears as dark blue/dark green powder and yields bright green colour when dissolved in water or other solvents."
  },
