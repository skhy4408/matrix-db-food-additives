  "natural_occurrence": {
    "found_in_nature": false,
    "natural_sources": [],
    "description": "A synthetic emulsifier created from sorbitol, stearic acid (three molecules), and ethylene oxide. Unlike other polysorbates which are mono-esters, this is a tri-ester with three stearic acid chains. The stearic acid can be derived from vegetable oils or animal fats."
  },
  "manufacturing": {
    "method": "chemical synthesis",
    "description": "Produced in two steps: (1) sorbitan (from sorbitol) is reacted with three molecules of stearic acid to form sorbitan tristearate, then (2) ethoxylated with approximately 20 units of ethylene oxide. The tri-ester structure makes it more lipophilic (fat-loving) than other polysorbates."
  },
  "other_uses": {
    "cosmetics": "Used in cosmetic formulations as an emulsifier, particularly in high-fat products.",
    "industrial": null,
    "pharmaceutical": "Used in pharmaceutical formulations as an emulsifying agent.",
    "household": null
  },
